---
const navLinks = [
  { label: 'Visit', href: '/#visit' },
  { label: 'About', href: '/about' },
  { label: 'Sermons', href: '/#sermons' },
  { label: 'Connect', href: '/#connect' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-paper/95 backdrop-blur-sm border-b border-ink/5 transition-all duration-300">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/images/svc-logo-black.png"
        alt="SVCC Logo"
        class="h-9 w-9 object-contain"
        width="36"
        height="36"
      />
      <span class="font-display font-semibold text-sm tracking-wide uppercase text-ink/70 group-hover:text-ink transition-colors">
        SV College Church
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-sans text-sm font-medium text-ink/60 hover:text-ink transition-colors relative after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:h-[1.5px] after:bg-accent after:transition-all hover:after:w-full"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/#visit"
          class="font-sans text-sm font-semibold bg-ink text-paper px-4 py-2 hover:bg-accent transition-colors duration-200"
        >
          Plan a Visit
        </a>
      </li>
    </ul>

    <!-- Mobile menu toggle (CSS-only checkbox trick) -->
    <label class="md:hidden cursor-pointer p-2 -mr-2" for="mobile-menu-toggle" aria-label="Toggle menu">
      <span class="block w-5 h-px bg-ink mb-1.5"></span>
      <span class="block w-5 h-px bg-ink mb-1.5"></span>
      <span class="block w-3 h-px bg-ink"></span>
    </label>
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />

    <!-- Mobile menu panel -->
    <div class="fixed inset-x-0 top-16 bg-paper border-b border-ink/10 px-6 py-6 hidden peer-checked:block md:hidden">
      <ul class="flex flex-col gap-5">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="font-sans text-base font-medium text-ink">
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a href="/#visit" class="inline-block font-sans text-sm font-semibold bg-ink text-paper px-5 py-2.5 hover:bg-accent transition-colors">
            Plan a Visit
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>
