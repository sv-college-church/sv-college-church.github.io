---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About" description="Launching kingdom workers from every college town.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Hero -->
    <section class="px-6 py-16 text-center md:py-28">
      <h1 class="mx-auto max-w-3xl font-sans font-black uppercase leading-tight text-ink" style="font-size: clamp(1.8rem, 4vw, 3.5rem);">
        Launching kingdom workers from every college town.
      </h1>
      <div class="mt-10 flex items-center justify-center gap-6">
        <a
          href="#statement"
          class="border border-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
        >
          Statement of Faith
        </a>
        <a
          href="#resources"
          class="bg-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-paper transition-colors duration-200 hover:bg-ink/70"
        >
          Resources
        </a>
      </div>
    </section>

    <!-- Info grid -->
    <section class="w-full border-t border-ink/15">
      <div class="about-grid">
        <div class="about-col">
          <p class="col-label">Our Story</p>
          <p class="col-body">
            In 2021, a team of college friends and volunteers relocated to Silicon Valley to establish a Christian community modeled after the early church. We believe every follower of Christ is called to be a kingdom worker — someone actively participating in sharing the gospel. We model ourselves after the Acts 2 church, emphasizing close-knit community as the ideal context for growing disciples.
          </p>
        </div>
        <div class="about-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Founded</p>
          <p class="col-display">2021<br />Silicon<br />Valley</p>
        </div>
        <div class="about-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Network</p>
          <p class="col-body">
            <a href="https://acts2.network/" target="_blank" rel="noopener noreferrer" class="network-link">Acts2 Network</a><br />
            <a href="https://www.acts2college.org/" target="_blank" rel="noopener noreferrer" class="network-link">Acts2 College</a><br />
            <a href="https://www.namb.net/send-network/" target="_blank" rel="noopener noreferrer" class="network-link">Send Network</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Leadership -->
    <section class="border-t border-ink/15 px-6 py-20 md:px-16">
      <p class="col-label mb-12">Leadership</p>
      <div class="leader-row">
        <!-- Bio -->
        <div class="leader-bio">
          <p class="leader-name">Steve &amp; Suzanne</p>
          <p class="col-body mt-4">
            Steve grew up in SoCal attending church, and after high school moved to Berkeley and studied Architecture. He planned to slowly "fade away" and jump instead into the freedom of college life, but God had other plans for his freshman year, as he experienced the word of God coming alive and addressing him personally and shortly after, he gave his life to following Jesus — and the rest is history!
          </p>
          <p class="col-body mt-4">
            Suzanne's aim after graduating UC Berkeley was to be a successful Asian American female living alone in a flat overlooking the San Francisco bay, sipping a latte while climbing the ranks of a Big Four Firm. But during her senior year, God changed that direction when she met Jesus and gave her life to his cause of ministering to college students, and her life has never been the same.
          </p>
          <p class="col-body mt-4">
            Steve & Suzanne lead our SVC church. They have a huge heart for students and youth ministry and founded Area Youth Ministry, a para-church organization where college students and alumni mentor students nationwide to strengthen their Christian faith. Their mission is to gospelize and engage the next generation of students for Christ. They have two kids: a son who just graduated from Purdue and a daughter who just started at UCSB.
          </p>
        </div>
        <!-- Photo -->
        <div class="leader-photo-wrap">
          <img src="/images/suhfam.png" alt="SVC directors Steve and Suzanne with their family" class="leader-photo" />
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="border-t border-ink/15 px-6 py-20 md:px-16">
      <p class="col-label mb-12">The Team</p>
      <div class="team-row">
        <img src="/images/mentors.png" alt="SVC staff group photo" class="team-photo" />
        <div class="team-bio">
          <p class="col-body">
            Our staff members work various roles — teachers, software engineers, product managers, finance professionals — but share a common story of transformation from their college years. Our collective passion is inviting current college students to experience the same life change through Jesus.
          </p>
        </div>
      </div>
    </section>

    <!-- Statement of Faith -->
    <section id="statement" class="border-t border-ink/15 px-6 py-20 md:px-16">
      <p class="col-label mb-12">Statement of Faith</p>

      <p class="col-body mb-16 max-w-2xl">
        Silicon Valley College Church is a member of the Southern Baptist Convention and SEND Network.
      </p>

      <div class="beliefs">
        <div class="belief">
          <h3 class="belief-title">The Bible</h3>
          <p class="col-body">The Bible is God's Holy Word, without error, and is the sole authority for life.</p>
          <p class="belief-refs">2 Tim. 3:16–17 · 2 Pet. 1:20–21 · Heb. 4:12 · Psalm 119:105 · John 1:1 · Isa. 40:8</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">The Godhead (Trinity)</h3>
          <p class="col-body">There is one God: The Father, the Son, and the Holy Spirit; who subsist in unity, and also as three separate distinct Persons.</p>
          <p class="belief-refs">Deut. 6:4 · Matt. 28:19 · John 10:30 · 2 Cor. 13:14</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">God the Father</h3>
          <p class="col-body">God is the first person of the Trinity and is the eternal, all-powerful, all-loving, just and perfectly holy, sovereign Ruler and Sustainer of the universe.</p>
          <p class="belief-refs">Gen. 1:1 · Eph. 4:6 · John 3:16 · Isa. 40:21–28</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">God the Son</h3>
          <p class="col-body">Jesus Christ is the second person of the Trinity and God's Son. He was born of a virgin as both God and man, lived a sinless life, died to atone for the sins of human beings, was buried, arose from the grave, ascended into heaven, and will literally return to earth.</p>
          <p class="belief-refs">John 1:1 · John 1:14 · Luke 1:30–35 · Phil. 2:5–8 · Acts 2:22–24 · John 20:20 · Acts 1:11</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">God the Holy Spirit</h3>
          <p class="col-body">The Holy Spirit is the divine helper, assistant, counselor and instructor. His work is to reveal Christ, convict of sin, lead to repentance, guide believers, comfort, strengthen, and sanctify the soul.</p>
          <p class="belief-refs">John 16:7–8 · 1 Cor. 6:19 · Gal. 5:22–23 · Rom. 8:26–28</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">Man</h3>
          <p class="col-body">Man is the special creation of God, made in His image. Man was created to glorify God, worship and serve Him. Man fell through sin by disobeying God, incurring both physical and spiritual death. All men are sinners, utterly lost, and totally incapable of saving himself by his own merit or effort.</p>
          <p class="belief-refs">Gen. 1:26 · Gen. 3:17–24 · Rom. 3:23 · Rom. 5:8 · Eph. 2:13</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">Salvation</h3>
          <p class="col-body">Salvation is a gift through repentance toward God and faith in Jesus Christ. Every person who truly is saved is eternally secure in the Lord Jesus Christ and will spend eternity in heaven, while those who die in their sins will spend eternity in hell.</p>
          <p class="belief-refs">Eph. 2:8–10 · John 3:14–16 · Rom. 10:9–10 · John 10:27–29 · John 14:6</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">The Church</h3>
          <p class="col-body">The church is a local body of baptized believers with the Lord Jesus Christ as the Head. The purpose of the church is to make Christ known to lost men and to make disciples, and glorify God on earth.</p>
          <p class="belief-refs">Matt. 28:18–20 · Eph. 4:11–16 · 1 Cor. 12:12–27 · Col. 1:24–29</p>
        </div>

        <div class="belief">
          <h3 class="belief-title">The Christian Life</h3>
          <p class="col-body">Every Christian should live for Christ to God's glory. By obedience to the Word of God, each believer should mature and progressively become more like Jesus. In the power of the Spirit, each believer should live a holy life; be part of a Christian community; and be personally involved in making disciples to fulfill the great commission.</p>
          <p class="belief-refs">Gal. 2:20 · 1 Pet. 1:15–16 · Matt. 28:18–20 · Acts 1:8 · John 15:8</p>
        </div>
      </div>
    </section>

    <!-- Resources -->
    <section id="resources" class="border-t border-ink/15 px-6 py-20 md:px-16">
      <p class="col-label mb-12">Resources</p>
      <div class="resources-grid">
        <a href="https://www.course101.online/" target="_blank" rel="noopener noreferrer" class="resource-card">
          <p class="resource-title">Course 101</p>
          <p class="col-body mt-2">7-week course on the intellectual foundations of Christianity providing space for conversation about life, faith, the Bible, and God.</p>
          <p class="resource-url">course101.online ↗</p>
        </a>
        <a href="https://devotions.acts2.network/" target="_blank" rel="noopener noreferrer" class="resource-card">
          <p class="resource-title">Daily Devotions</p>
          <p class="col-body mt-2">We read and reflect on God's Word daily. Click through to learn more about our daily devotional text.</p>
          <p class="resource-url">devotions.acts2.network ↗</p>
        </a>
        <a href="https://sites.google.com/view/bible-reading-resources/home" target="_blank" rel="noopener noreferrer" class="resource-card">
          <p class="resource-title">Bible Resources</p>
          <p class="col-body mt-2">Bible Reading site containing Bible Project Videos, top verses to memorize, top chapters to read, Bible Reading plans, and so much more.</p>
          <p class="resource-url">Bible Reading Resources ↗</p>
        </a>
        <a href="https://www.apologeticsqna.com" target="_blank" rel="noopener noreferrer" class="resource-card">
          <p class="resource-title">Apologetics</p>
          <p class="col-body mt-2">Got questions about the Christian faith? Here are answers to commonly asked questions.</p>
          <p class="resource-url">apologeticsqna.com ↗</p>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .col-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(20 20 20 / 0.35);
  }

  .col-body {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.75;
    color: rgb(20 20 20 / 0.65);
  }

  .col-display {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: rgb(20 20 20);
  }

  /* Info grid */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .about-col {
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .about-col {
      padding: 3rem 3.5rem;
    }
  }

  /* Leadership */
  .leader-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .leader-row {
      grid-template-columns: 3fr 2fr;
      gap: 6rem;
      align-items: start;
    }
  }

  .leader-photo {
    width: 100%;
    aspect-ratio: 3 / 2;
    border: 1.5px solid rgb(20 20 20 / 0.2);
    background: rgb(20 20 20 / 0.04);
    object-fit: cover;
    object-position: center;
  }

  .leader-name {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: rgb(20 20 20);
  }

  /* Team */
  .team-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .team-row {
      grid-template-columns: 3fr 2fr;
      gap: 6rem;
      align-items: start;
    }
  }

  .team-bio {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .team-photo {
    width: 100%;
    aspect-ratio: 3 / 2;
    border: 1.5px solid rgb(20 20 20 / 0.2);
    background: rgb(20 20 20 / 0.04);
    object-fit: cover;
    object-position: center top;
  }

  /* Statement of faith */
  .beliefs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .beliefs {
      grid-template-columns: 1fr 1fr;
    }
  }

  .belief {
    padding: 2.5rem 0;
    border-top: 1px solid rgb(20 20 20 / 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .belief {
      padding: 2.5rem 3rem 2.5rem 0;
    }

    .belief:nth-child(even) {
      padding-left: 3rem;
      padding-right: 0;
      border-left: 1px solid rgb(20 20 20 / 0.1);
    }
  }

  .belief-title {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(20 20 20);
  }

  /* Resources */
  .resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .resource-card {
    display: block;
    padding: 2.5rem 0;
    border-top: 1px solid rgb(20 20 20 / 0.1);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .resource-card:hover {
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .resource-card {
      padding: 2.5rem 3rem 2.5rem 0;
    }

    .resource-card:nth-child(even) {
      padding-left: 3rem;
      padding-right: 0;
      border-left: 1px solid rgb(20 20 20 / 0.1);
    }
  }

  .resource-title {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(20 20 20);
  }

  .resource-url {
    font-size: 0.7rem;
    color: rgb(20 20 20 / 0.3);
    letter-spacing: 0.02em;
    margin-top: 1rem;
  }

  .network-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(20 20 20 / 0.3);
    transition: text-decoration-color 0.2s;
  }

  .network-link:hover {
    text-decoration-color: rgb(20 20 20);
  }

  .belief-refs {
    font-size: 0.7rem;
    color: rgb(20 20 20 / 0.3);
    letter-spacing: 0.02em;
    margin-top: 0.25rem;
  }
</style>
