---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import suhfam from '../assets/images/suhfam.png';
import mentors from '../assets/images/mentors.png';
---

<BaseLayout title="About | Silicon Valley College Church" description="Silicon Valley College Church launches kingdom workers from college campuses across the South Bay — Stanford, SJSU, SCU, UCSC, and De Anza.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Hero -->
    <section class="hero-section flex flex-col items-center justify-center px-6 text-center">
      <h1 class="hero-title mx-auto max-w-5xl font-sans font-black uppercase leading-tight text-ink" style="font-size: clamp(2.2rem, 4.8vw, 4.2rem);">
        <span class="hero-word">Launching</span>
        <span class="hero-word">kingdom</span>
        <span class="hero-word">workers</span>
        <span class="hero-word">from</span>
        <span class="hero-word">every</span>
        <span class="hero-word">college</span>
        <span class="hero-word">town.</span>
      </h1>
      <div class="scroll-hint mt-16" aria-hidden="true">
        <a href="#story" class="scroll-arrow" tabindex="-1">↓</a>
      </div>
    </section>

    <!-- Our Story -->
    <section id="story" class="reveal-section border-t border-ink/10">
      <div class="reveal-inner content-col" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">Our Story</p>
        <p class="body-text">
          In 2021, a team of college friends moved to Silicon Valley to start a church for students, modeled after the early church in Acts 2. We want to be a place where every student can come to know Jesus — a place to belong, believe, and become more like him.
        </p>
      </div>
    </section>

    <!-- Leadership -->
    <section class="reveal-section border-t border-ink/10">
      <div class="reveal-inner content-col" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">Leadership</p>
        <Image src={suhfam} alt="SVC directors Steve and Suzanne with their family" class="section-photo" />
        <p class="display-name">Steve & Suzanne</p>
        <p class="body-text">
          Steve and Suzanne met at UC Berkeley — Steve studying architecture, Suzanne climbing the ranks at a Big Four firm. Both had their plans rerouted when they encountered Jesus during college, and they've spent the years since pouring into students. They lead SVC, founded Area Youth Ministry, and have two kids: a Purdue grad and a UCSB freshman. Their mission is simple — engage the next generation of students for Christ.
        </p>
      </div>
    </section>

    <!-- The Team -->
    <section class="reveal-section border-t border-ink/10">
      <div class="reveal-inner content-col" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">The Team</p>
        <Image src={mentors} alt="SVC staff group photo" class="section-photo" />
        <p class="body-text">
          Our staff work as teachers, engineers, product managers, and finance professionals — but share a common story of transformation from their college years. Our passion is inviting current students to experience the same life change through Jesus. Reach out to any of us — we'd love to share our stories with you.
        </p>
      </div>
    </section>

    <!-- Statement of Faith -->
    <section id="statement" class="compact-section border-t border-ink/10">
      <div class="compact-inner" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">Statement of Faith</p>
        <p class="compact-note">Silicon Valley College Church is a member of the Southern Baptist Convention and SEND Network.</p>

        <div class="accordion">
          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>The Bible</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>The Bible is God's Holy Word, without error, and is the sole authority for life.</p>
              <p class="belief-refs">2 Tim. 3:16–17 · 2 Pet. 1:20–21 · Heb. 4:12 · Psalm 119:105 · John 1:1 · Isa. 40:8</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>The Godhead (Trinity)</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>There is one God: The Father, the Son, and the Holy Spirit; who subsist in unity, and also as three separate distinct Persons.</p>
              <p class="belief-refs">Deut. 6:4 · Matt. 28:19 · John 10:30 · 2 Cor. 13:14</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>God the Father</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>God is the first person of the Trinity and is the eternal, all-powerful, all-loving, just and perfectly holy, sovereign Ruler and Sustainer of the universe.</p>
              <p class="belief-refs">Gen. 1:1 · Eph. 4:6 · John 3:16 · Isa. 40:21–28</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>God the Son</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>Jesus Christ is the second person of the Trinity and God's Son. He was born of a virgin as both God and man, lived a sinless life, died to atone for the sins of human beings, was buried, arose from the grave, ascended into heaven, and will literally return to earth.</p>
              <p class="belief-refs">John 1:1 · John 1:14 · Luke 1:30–35 · Phil. 2:5–8 · Acts 2:22–24 · John 20:20 · Acts 1:11</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>God the Holy Spirit</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>The Holy Spirit is the divine helper, assistant, counselor and instructor. His work is to reveal Christ, convict of sin, lead to repentance, guide believers, comfort, strengthen, and sanctify the soul.</p>
              <p class="belief-refs">John 16:7–8 · 1 Cor. 6:19 · Gal. 5:22–23 · Rom. 8:26–28</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>Man</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>Man is the special creation of God, made in His image. Man was created to glorify God, worship and serve Him. Man fell through sin by disobeying God, incurring both physical and spiritual death. All men are sinners, utterly lost, and totally incapable of saving himself by his own merit or effort.</p>
              <p class="belief-refs">Gen. 1:26 · Gen. 3:17–24 · Rom. 3:23 · Rom. 5:8 · Eph. 2:13</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>Salvation</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>Salvation is a gift through repentance toward God and faith in Jesus Christ. Every person who truly is saved is eternally secure in the Lord Jesus Christ and will spend eternity in heaven, while those who die in their sins will spend eternity in hell.</p>
              <p class="belief-refs">Eph. 2:8–10 · John 3:14–16 · Rom. 10:9–10 · John 10:27–29 · John 14:6</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>The Church</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>The church is a local body of baptized believers with the Lord Jesus Christ as the Head. The purpose of the church is to make Christ known to lost men and to make disciples, and glorify God on earth.</p>
              <p class="belief-refs">Matt. 28:18–20 · Eph. 4:11–16 · 1 Cor. 12:12–27 · Col. 1:24–29</p>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              <span>The Christian Life</span><span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content">
              <p>Every Christian should live for Christ to God's glory. By obedience to the Word of God, each believer should mature and progressively become more like Jesus. In the power of the Spirit, each believer should live a holy life; be part of a Christian community; and be personally involved in making disciples to fulfill the great commission.</p>
              <p class="belief-refs">Gal. 2:20 · 1 Pet. 1:15–16 · Matt. 28:18–20 · Acts 1:8 · John 15:8</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Resources -->
    <section id="resources" class="compact-section border-t border-ink/10">
      <div class="compact-inner" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">Resources</p>

        <div class="resource-list">
          <a href="https://www.course101.online/" target="_blank" rel="noopener noreferrer" class="resource-row">
            <div>
              <p class="resource-title">Course 101</p>
              <p class="resource-desc">7-week course on the intellectual foundations of Christianity.</p>
            </div>
            <span class="resource-arrow">↗</span>
          </a>
          <a href="https://devotions.acts2.network/" target="_blank" rel="noopener noreferrer" class="resource-row">
            <div>
              <p class="resource-title">Daily Devotions</p>
              <p class="resource-desc">Read and reflect on God's Word daily with our community.</p>
            </div>
            <span class="resource-arrow">↗</span>
          </a>
          <a href="https://sites.google.com/view/bible-reading-resources/home" target="_blank" rel="noopener noreferrer" class="resource-row">
            <div>
              <p class="resource-title">Bible Resources</p>
              <p class="resource-desc">Videos, reading plans, top verses to memorize, and more.</p>
            </div>
            <span class="resource-arrow">↗</span>
          </a>
          <a href="https://apologeticsqna.com" target="_blank" rel="noopener noreferrer" class="resource-row">
            <div>
              <p class="resource-title">Apologetics</p>
              <p class="resource-desc">Answers to commonly asked questions about the Christian faith.</p>
            </div>
            <span class="resource-arrow">↗</span>
          </a>
        </div>

        <div class="network-links">
          <p class="section-label" style="margin-bottom: 1rem;">Network</p>
          <p class="network-row">
            <a href="https://acts2.network/" target="_blank" rel="noopener noreferrer">Acts2 Network ↗</a>
            <a href="https://www.acts2college.org/" target="_blank" rel="noopener noreferrer">Acts2 College ↗</a>
            <a href="https://www.namb.net/send-network/" target="_blank" rel="noopener noreferrer">Send Network ↗</a>
          </p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    min-height: 75vh;
  }

  @media (max-width: 640px) {
    .hero-section {
      min-height: 55vh;
    }
  }

  /* Word-by-word reveal */
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: word-rise 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .hero-word:nth-child(1) { animation-delay: 0.1s; }
  .hero-word:nth-child(2) { animation-delay: 0.22s; }
  .hero-word:nth-child(3) { animation-delay: 0.34s; }
  .hero-word:nth-child(4) { animation-delay: 0.46s; }
  .hero-word:nth-child(5) { animation-delay: 0.58s; }
  .hero-word:nth-child(6) { animation-delay: 0.7s; }
  .hero-word:nth-child(7) { animation-delay: 0.82s; }

  @keyframes word-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll-hint {
    opacity: 0;
    animation: hint-fade 0.4s ease forwards;
    animation-delay: 1.4s;
  }

  @keyframes hint-fade {
    to { opacity: 1; }
  }

  .scroll-arrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #D91C2A;
    text-decoration: none;
    animation: nudge 2.4s ease-in-out infinite;
    animation-delay: 1.4s;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  .scroll-arrow:hover {
    opacity: 0.7;
  }

  @keyframes nudge {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(5px); opacity: 1; }
  }

  /* ── Reveal sections (full viewport) ── */
  .reveal-section {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
  }

  @media (max-width: 640px) {
    .reveal-section {
      min-height: unset;
      padding: 4rem 1.5rem;
    }
  }

  .reveal-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .content-col {
    max-width: 55rem;
  }

  /* ── data-animate ── */
  [data-animate] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Shared elements ── */
  .section-rule {
    width: 1px;
    height: 3.5rem;
    background: rgb(10 10 10 / 0.18);
    margin-bottom: 1.75rem;
  }

  .section-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(10 10 10 / 0.60);
    margin-bottom: 2rem;
  }

  .body-text {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.15rem, 1.8vw, 1.5rem);
    font-weight: 600;
    line-height: 1.75;
    color: rgb(10 10 10 / 0.78);
  }

  .display-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.02em;
    color: rgb(10 10 10);
    margin-bottom: 2rem;
  }

  .section-photo {
    width: 100%;
    max-width: 44rem;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    border: 1.5px solid rgb(10 10 10 / 0.12);
    margin-bottom: 2.5rem;
  }

  /* ── Compact sections (Statement of Faith, Resources) ── */
  .compact-section {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 5rem 2rem;
  }

  .compact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 50rem;
  }

  .compact-note {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgb(10 10 10 / 0.62);
    margin-bottom: 2.5rem;
  }

  /* ── Accordion ── */
  .accordion {
    width: 100%;
    text-align: left;
  }

  .accordion-item {
    border-top: 1px solid rgb(10 10 10 / 0.1);
  }

  .accordion-item:last-child {
    border-bottom: 1px solid rgb(10 10 10 / 0.1);
  }

  .accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgb(10 10 10);
    transition: color 0.2s ease;
  }

  .accordion-trigger:hover {
    color: rgb(10 10 10 / 0.6);
  }

  .accordion-icon {
    font-size: 1.2rem;
    font-weight: 300;
    transition: transform 0.25s ease;
    color: rgb(10 10 10 / 0.4);
  }

  .accordion-item.is-open .accordion-icon {
    transform: rotate(45deg);
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .accordion-content p {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgb(10 10 10 / 0.6);
    padding-bottom: 0.75rem;
  }

  .belief-refs {
    font-size: 0.7rem;
    color: rgb(10 10 10 / 0.6);
    letter-spacing: 0.02em;
    padding-bottom: 1.5rem;
  }

  /* ── Resources ── */
  .resource-list {
    width: 100%;
    text-align: left;
  }

  .resource-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgb(10 10 10 / 0.1);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .resource-row:last-child {
    border-bottom: 1px solid rgb(10 10 10 / 0.1);
  }

  .resource-row:hover {
    opacity: 0.6;
  }

  .resource-title {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(10 10 10);
    margin-bottom: 0.3rem;
  }

  .resource-desc {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgb(10 10 10 / 0.65);
  }

  .resource-arrow {
    font-size: 1.1rem;
    color: rgb(10 10 10 / 0.60);
    flex-shrink: 0;
  }

  /* ── Network links ── */
  .network-links {
    margin-top: 3rem;
    text-align: center;
  }

  .network-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .network-row a {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgb(10 10 10 / 0.62);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .network-row a:hover {
    color: rgb(10 10 10);
  }
</style>

<script>
  // Accordion — one open at a time
  document.querySelectorAll('.accordion-trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var item = trigger.parentElement;
      var content = item.querySelector('.accordion-content');
      var isOpen = item.classList.contains('is-open');

      // Close all
      document.querySelectorAll('.accordion-item').forEach(function (el) {
        el.classList.remove('is-open');
        el.querySelector('.accordion-trigger').setAttribute('aria-expanded', 'false');
        el.querySelector('.accordion-content').style.maxHeight = null;
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });
  });
</script>
