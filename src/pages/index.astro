---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getImage } from 'astro:assets';

// Community photos — all 23 imported, Astro optimises at build time.
// JS picks a random 4 per page load via the existing shuffle logic.
import svc01 from '../assets/images/community/svc-01.webp';
import svc02 from '../assets/images/community/svc-02.webp';
import svc03 from '../assets/images/community/svc-03.webp';
import svc04 from '../assets/images/community/svc-04.webp';
import svc05 from '../assets/images/community/svc-05.webp';
import svc06 from '../assets/images/community/svc-06.webp';
import svc07 from '../assets/images/community/svc-07.webp';
import svc08 from '../assets/images/community/svc-08.webp';
import svc09 from '../assets/images/community/svc-09.webp';
import svc10 from '../assets/images/community/svc-10.webp';
import svc11 from '../assets/images/community/svc-11.webp';
import svc12 from '../assets/images/community/svc-12.webp';
import svc13 from '../assets/images/community/svc-13.webp';
import svc14 from '../assets/images/community/svc-14.webp';
import svc15 from '../assets/images/community/svc-15.webp';
import svc16 from '../assets/images/community/svc-16.webp';
import svc17 from '../assets/images/community/svc-17.webp';
import svc18 from '../assets/images/community/svc-18.webp';
import svc19 from '../assets/images/community/svc-19.webp';
import svc20 from '../assets/images/community/svc-20.webp';
import svc21 from '../assets/images/community/svc-21.webp';
import svc22 from '../assets/images/community/svc-22.webp';
import svc23 from '../assets/images/community/svc-23.webp';

const allSources = [
  svc01, svc02, svc03, svc04, svc05, svc06, svc07, svc08,
  svc09, svc10, svc11, svc12, svc13, svc14, svc15, svc16,
  svc17, svc18, svc19, svc20, svc21, svc22, svc23,
];

const optimized = await Promise.all(
  allSources.map(src => getImage({ src, width: 800, format: 'webp' }))
);
const photoUrls = optimized.map(img => img.src);
---

<BaseLayout title="Silicon Valley College Church" description="A church for young adults and college students in Silicon Valley.">
  <Nav />

  <main class="pt-20 md:pt-32 main-content">

    <!-- Easter announcement banner -->
    <div class="announcement-banner">
      <span class="banner-text">
        <span class="label-full">🐣 EASTER SUNDAY · APR 5 · THE KINGS ACADEMY · SUNNYVALE</span>
        <span class="label-short">🐣 EASTER · APR 5</span>
      </span>
      <a href="/church" class="easter-link">
        <span class="label-full">SEE DETAILS →</span>
        <span class="label-short">INFO →</span>
      </a>
    </div>

    <section id="hero" class="bg-paper">

      <!-- Text: fades in above photos after shrink -->
      <div id="text-wrapper">
        <h1 id="hero-text" class="font-sans font-black uppercase leading-none">
          <span class="hero-word" data-index="0">Welcome</span>
          <span class="hero-word" data-index="1">to</span>
          <br />
          <span class="hero-line2">Silicon Valley College Church</span>
        </h1>
      </div>

      <!-- Stack container: stays centered -->
      <div id="polaroid-stack" data-photos={JSON.stringify(photoUrls)}>
        <!-- Scale container: handles shrink -->
        <div id="polaroid-scale">
          <!-- Breathe container: handles idle ebb & flow -->
          <div id="polaroid-breathe">
            <div class="polaroid-card"><div class="card-inner"><img alt="SVC community" draggable="false" /></div></div>
            <div class="polaroid-card"><div class="card-inner"><img alt="SVC community" draggable="false" /></div></div>
            <div class="polaroid-card"><div class="card-inner"><img alt="SVC community" draggable="false" /></div></div>
            <div class="polaroid-card"><div class="card-inner"><img alt="SVC community" draggable="false" /></div></div>
          </div>
        </div>
      </div>

      <!-- Class of 2030 badge -->
      <a href="/class-of-2030" id="class-badge" aria-label="Class of 2030 — welcome">
        <div class="badge-ring" aria-hidden="true">
          <span style="--a:0">✦</span>
          <span style="--a:24">W</span>
          <span style="--a:36">E</span>
          <span style="--a:48">L</span>
          <span style="--a:60">C</span>
          <span style="--a:72">O</span>
          <span style="--a:84">M</span>
          <span style="--a:96">E</span>
          <span style="--a:120">✦</span>
          <span style="--a:144">W</span>
          <span style="--a:156">E</span>
          <span style="--a:168">L</span>
          <span style="--a:180">C</span>
          <span style="--a:192">O</span>
          <span style="--a:204">M</span>
          <span style="--a:216">E</span>
          <span style="--a:240">✦</span>
          <span style="--a:264">W</span>
          <span style="--a:276">E</span>
          <span style="--a:288">L</span>
          <span style="--a:300">C</span>
          <span style="--a:312">O</span>
          <span style="--a:324">M</span>
          <span style="--a:336">E</span>
        </div>
        <div class="badge-center-content">
          <span class="badge-classof">CLASS</span>
          <span class="badge-dot">·</span>
          <span class="badge-year-num">2030</span>
        </div>
      </a>

    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Nav hidden on load, fades in at 2.8s */
  header {
    animation: navFadeIn 0.4s ease 2.8s both;
  }
  footer {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  footer.is-visible {
    opacity: 1;
  }
  @keyframes navFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Homepage: fit everything in the viewport, no scrolling needed */
  body {
    height: 100svh;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  /* ── Easter announcement banner ── */
  .announcement-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    background: #0A0A0A;
    padding: clamp(0.6rem, 1.4vh, 1.1rem) 2rem;
    position: relative;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .announcement-banner.is-visible {
    opacity: 1;
  }

  .banner-text {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F5F5F0;
    line-height: 1;
  }

  .easter-link {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    line-height: 1;
    color: #F5F5F0;
    background: #D91C2A;
    padding: 0.65rem 1.6rem;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .easter-link:hover { background: #b51623; }

  .label-short { display: none; }

  @media (max-width: 640px) {
    .announcement-banner {
      gap: 0.6rem;
      padding: 0.7rem 1rem;
    }
    .banner-text .label-full { display: none; }
    .banner-text .label-short { display: inline; }
    .easter-link .label-full { display: none; }
    .easter-link .label-short { display: inline; }
    .banner-text {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
    }
    .easter-link {
      font-size: 0.68rem;
      padding: 0.45rem 0.85rem;
      letter-spacing: 0.14em;
      flex-shrink: 0;
    }
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* Match Nav's short-viewport height reduction */
  @media (min-width: 768px) and (max-height: 760px) {
    .main-content {
      padding-top: 5rem; /* matches Nav's 5rem height on short viewports */
    }
  }

  #hero {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  /* Prevent horizontal scrollbar from fan animation.
     Use `clip` (not `hidden`) so <html> does NOT become a scroll container,
     which would otherwise require two scroll attempts to reach the top/bottom. */
  :global(html) {
    overflow-x: clip;
  }

  /* ── Stack: centered, no slide ── */
  #polaroid-stack {
    --card-w: clamp(240px, 46vw, 580px);
    --card-h: calc(var(--card-w) + 42px);

    position: absolute;
    width: var(--card-w);
    height: var(--card-h);
    left: 50%;
    top: 50%;
    margin-left: calc(var(--card-w) / -2);
    margin-top: calc(var(--card-h) / -2);
    transition: top 0.8s cubic-bezier(0.65, 0, 0.35, 1);
    cursor: default;
  }

  /* Position set dynamically by JS based on available space */

  /* Invisible hover zone — extends hit area for horizontal fan (mouse devices only) */
  @media (hover: hover) and (pointer: fine) {
    #polaroid-stack.settled::after {
      content: '';
      position: absolute;
      inset: -100px -1100px;
    }
  }

  /* ── Scale wrapper: shrink animation ── */
  #polaroid-scale {
    width: 100%;
    height: 100%;
    transform-origin: center center;
    transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
  }

  /* ── Breathe wrapper: idle ebb & flow ── */
  #polaroid-breathe {
    width: 100%;
    height: 100%;
  }

  #polaroid-breathe.breathing {
    animation: breathe 3.5s ease-in-out infinite;
  }

  #polaroid-breathe.fanned {
    animation-play-state: paused;
  }

  @keyframes breathe {
    0%, 100% { transform: translateY(0px)   scale(1);     }
    50%       { transform: translateY(-6px)  scale(1.018); }
  }

  /* ── Individual Polaroid cards ── */
  .polaroid-card {
    position: absolute;
    inset: 0;
    background: #ffffff;
    border-radius: 10px;
    padding: 14px 14px 56px;
    box-sizing: border-box;
    box-shadow:
      0 2px 6px  rgba(0, 0, 0, 0.07),
      0 8px 24px rgba(0, 0, 0, 0.11),
      0 24px 52px rgba(0, 0, 0, 0.07);
    opacity: 0;
    /* transform set by JS */
  }

  .card-inner {
    width: 100%;
    height: 100%;
    border-radius: 3px;
    overflow: hidden;
  }

  .card-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
  }

  /* ── Text wrapper: above the photos ── */
  #text-wrapper {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 3%;
    pointer-events: none;
    text-align: center;
    width: max-content;
    max-width: 90vw;
  }

  #text-wrapper.visible {
    pointer-events: auto;
  }

  #hero-text {
    color: var(--color-ink, #0A0A0A);
    margin: 0;
    text-align: center;
  }

  .hero-word {
    display: inline-block;
    font-size: clamp(1.5rem, min(4vw, 6vh), 4rem);
    letter-spacing: 0.15em;
    opacity: 0;
    transform: translateY(0.2em);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .hero-line2 {
    display: block;
    font-size: clamp(2.5rem, min(7.5vw, 11vh), 7.5rem);
    opacity: 0;
    transform: translateY(0.15em);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .hero-word.visible,
  .hero-line2.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Class of 2030 Badge ── */
  #class-badge {
    --badge-size: clamp(120px, 22vh, 172px);
    --ring-r: calc(var(--badge-size) / -2.65);
    position: absolute;
    bottom: 5%;
    right: 5%;
    width: var(--badge-size);
    height: var(--badge-size);
    border-radius: 50%;
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    z-index: 20;
    opacity: 0;
    cursor: pointer;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.3),
      0 0 0 0px rgba(217, 28, 42, 0);
  }

  #class-badge::before {
    content: '';
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px solid rgba(245, 245, 240, 0.12);
    pointer-events: none;
  }

  #class-badge::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid rgba(217, 28, 42, 0.55);
    opacity: 0;
    pointer-events: none;
  }

  #class-badge.is-live {
    animation: badgePopIn 0.65s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
  }

  #class-badge.is-breathing {
    opacity: 1;
    transform: scale(1);
    animation: badgeBreathe 2.8s ease-in-out infinite;
    transition: transform 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  #class-badge:hover {
    transform: scale(1.13) !important;
  }

  #class-badge.is-breathing::after {
    animation: badgePulseRing 2.8s ease-out infinite;
  }

  @keyframes badgePopIn {
    0%   { opacity: 0; transform: scale(0.72) rotate(-8deg); }
    65%  { opacity: 1; transform: scale(1.08) rotate(2deg); }
    82%  { transform: scale(0.97) rotate(0deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes badgeBreathe {
    0%, 100% {
      box-shadow:
        0 4px 20px rgba(0, 0, 0, 0.3),
        0 0 0 0px rgba(217, 28, 42, 0.45);
    }
    50% {
      box-shadow:
        0 6px 32px rgba(0, 0, 0, 0.2),
        0 0 0 14px rgba(217, 28, 42, 0);
    }
  }

  @keyframes badgePulseRing {
    0%   { opacity: 0.65; transform: scale(1); }
    100% { opacity: 0;    transform: scale(1.4); }
  }

  @keyframes badgeRingRotate {
    to { transform: rotate(360deg); }
  }

  .badge-ring {
    position: absolute;
    inset: 0;
    animation: badgeRingRotate 18s linear infinite;
  }

  .badge-ring span {
    position: absolute;
    left: 50%;
    top: 50%;
    margin: -0.5em 0 0 -0.5em;
    width: 1em;
    height: 1em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: clamp(7px, 1.3vh, 10px);
    font-weight: 600;
    color: #F5F5F0;
    text-transform: uppercase;
    line-height: 1;
    transform-origin: center center;
    transform: rotate(calc(var(--a) * 1deg)) translateY(var(--ring-r, -65px));
  }

  .badge-center-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    pointer-events: none;
    user-select: none;
  }

  .badge-classof {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: clamp(6px, 1.2vh, 9px);
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(245, 245, 240, 0.6);
    text-transform: uppercase;
  }

  .badge-dot {
    color: #D91C2A;
    font-size: clamp(11px, 2.3vh, 18px);
    line-height: 0.8;
  }

  .badge-year-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(17px, 3.8vh, 30px);
    font-weight: 700;
    font-style: italic;
    color: #F5F5F0;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Short viewport / high-DPI scaling handled dynamically by JS */

  /* ── Mobile ── */
  @media (max-width: 767px) {
    #polaroid-stack {
      --card-w: clamp(220px, 78vw, 380px);
    }

    #text-wrapper {
      width: auto;
      max-width: 85vw;
      padding: 0 16px;
    }

    /* Smaller badge at bottom-right on mobile */
    #class-badge {
      --ring-r: -38px;
      width: 96px;
      height: 96px;
      top: auto;
      bottom: 4%;
      right: 4%;
      left: auto;
      margin-left: 0;
    }

    .badge-ring span { font-size: 8px; }
    .badge-classof { font-size: 7px; }
    .badge-year-num { font-size: 17px; }
    .badge-dot { font-size: 11px; }
  }
</style>

<script>
  // ── Photo pool — read optimized URLs from the data attribute ──
  const ALL_PHOTOS: string[] = JSON.parse(
    document.getElementById('polaroid-stack')!.dataset.photos!
  );

  // Fisher-Yates shuffle
  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // Fan: flat horizontal spread, wide enough to see each photo fully
  const FAN_X = [-900, -300, 300, 900];

  function fanTransform(i: number): string {
    return `translate(${FAN_X[i]}px, 0px)`;
  }

  // Wrap in astro:page-load so it re-runs on View Transitions navigation
  document.addEventListener('astro:page-load', () => {
    const cards     = Array.from(document.querySelectorAll<HTMLElement>('.polaroid-card'));
    const scaleEl   = document.getElementById('polaroid-scale');
    const breatheEl = document.getElementById('polaroid-breathe');
    const stackEl   = document.getElementById('polaroid-stack');
    const textWrap  = document.getElementById('text-wrapper');

    // Bail if we're not on the homepage
    if (!cards.length || !scaleEl || !breatheEl || !stackEl || !textWrap) return;

    // Reset DOM state (View Transitions preserves classes/styles from previous visit)
    scaleEl.style.transform = '';
    stackEl.style.top = '';
    stackEl.classList.remove('settled');
    delete stackEl.dataset.dynScale;
    breatheEl.classList.remove('breathing', 'fanned');
    textWrap.classList.remove('visible');
    document.querySelectorAll<HTMLElement>('.hero-word, .hero-line2').forEach(el => el.classList.remove('visible'));
    const badge = document.getElementById('class-badge');
    if (badge) badge.classList.remove('is-live', 'is-breathing');
    const banner = document.querySelector<HTMLElement>('.announcement-banner');
    if (banner) banner.classList.remove('is-visible');
    const footer = document.querySelector('footer');
    if (footer) footer.classList.remove('is-visible');

    // Assign shuffled photos to the 4 static cards
    const picked = shuffle(ALL_PHOTOS).slice(0, cards.length);
    cards.forEach((card, i) => {
      const img = card.querySelector('img')!;
      img.src = picked[i];
    });

    // ── Drop cards in one by one, store stack transform ──
    cards.forEach((card, i) => {
      const dx  = +(Math.random() * 16 - 8).toFixed(2);
      const dy  = +(Math.random() * 16 - 8).toFixed(2);
      const rot = +(Math.random() * 12 - 6).toFixed(2);

      const stackTransform = `translate(${dx}px, ${dy}px) rotate(${rot}deg)`;
      card.dataset.stack   = stackTransform;

      card.style.zIndex    = String(i + 1);
      card.style.transition = 'none';
      card.style.transform = `translate(${dx}px, ${dy - 80}px) rotate(${rot}deg)`;
      card.style.opacity   = '0';

      setTimeout(() => {
        card.style.transition = 'transform 0.13s cubic-bezier(0.34, 1.3, 0.64, 1), opacity 0.08s ease';
        card.style.opacity    = '1';
        card.style.transform  = stackTransform;
      }, i * 160 + 60);
    });

    // ── 0.7s: shrink — scale dynamically based on available viewport space ──
    // The text is already in the DOM (opacity 0) so we can measure its height.
    setTimeout(() => {
      const heroEl  = stackEl.parentElement as HTMLElement;
      const heroH   = heroEl.getBoundingClientRect().height;
      const heroTop = heroEl.getBoundingClientRect().top;
      const textBottom = textWrap.getBoundingClientRect().bottom - heroTop;
      const cardH   = stackEl.offsetHeight;
      const gap     = 32;   // min space between text and card top edge
      const bottomPad = 16; // min space above hero bottom edge

      const availableH = heroH - textBottom - gap - bottomPad;
      const scale = Math.min(0.55, Math.max(0.28, availableH / cardH));

      scaleEl.style.transform = `scale(${scale})`;
      stackEl.dataset.dynScale = String(scale);
    }, 700);

    // ── 1.5s: text appears, stack repositions to center in remaining space ──
    const words = Array.from(document.querySelectorAll<HTMLElement>('.hero-word'));
    const line2 = document.querySelector<HTMLElement>('.hero-line2')!;

    setTimeout(() => {
      textWrap.classList.add('visible');
      words[0]?.classList.add('visible');

      requestAnimationFrame(() => {
        const heroEl  = stackEl.parentElement as HTMLElement;
        const heroRect = heroEl.getBoundingClientRect();
        const heroH   = heroRect.height;
        const textBottom = textWrap.getBoundingClientRect().bottom - heroRect.top;
        const scale   = parseFloat(stackEl.dataset.dynScale || '0.55');
        const visualH = stackEl.offsetHeight * scale;
        const gap     = 24;
        const bottomPad = 16;

        // Center the scaled card in the space between text and hero bottom
        const spaceTop    = textBottom + gap;
        const spaceBottom = heroH - bottomPad;
        const centerY     = (spaceTop + spaceBottom) / 2;

        // Clamp: card top must clear text, card bottom must stay in hero
        const minCenter = spaceTop + visualH / 2;
        const maxCenter = spaceBottom - visualH / 2;
        const finalCenter = Math.max(minCenter, Math.min(centerY, maxCenter));

        stackEl.style.top = (finalCenter / heroH * 100) + '%';
      });
    }, 1500);

    setTimeout(() => {
      words[1]?.classList.add('visible');
    }, 1800);

    setTimeout(() => {
      line2.classList.add('visible');
    }, 2200);

    // ── 3.2s: class-of-2030 badge pops in + banner fades in ──
    setTimeout(() => {
      if (badge) {
        badge.classList.add('is-live');
        setTimeout(() => badge.classList.add('is-breathing'), 1100);
      }
      const banner = document.querySelector('.announcement-banner');
      if (banner) banner.classList.add('is-visible');
      const footer = document.querySelector('footer');
      if (footer) footer.classList.add('is-visible');
    }, 3200);

    // ── 2.6s: settled — start breathing + enable fan (desktop) or swipe (mobile) ──
    setTimeout(() => {
      stackEl.classList.add('settled');
      breatheEl.classList.add('breathing');

      const isMouse = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      if (isMouse) {
        // ── Desktop: hover to fan ──
        let leaveTimer: ReturnType<typeof setTimeout> | null = null;

        stackEl.addEventListener('mouseenter', () => {
          if (leaveTimer) { clearTimeout(leaveTimer); leaveTimer = null; }
          breatheEl.classList.add('fanned');
          cards.forEach((card, i) => {
            card.style.transition = `transform 0.45s cubic-bezier(0.34, 1.15, 0.64, 1) ${i * 30}ms`;
            card.style.transform  = fanTransform(i);
          });
        });

        stackEl.addEventListener('mouseleave', () => {
          leaveTimer = setTimeout(() => {
            breatheEl.classList.remove('fanned');
            cards.forEach((card) => {
              card.style.transition = 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
              card.style.transform  = card.dataset.stack!;
            });
          }, 80);
        });
      } else {
        // ── Mobile: swipe to cycle through cards ──
        // order[0] = bottom card, order[last] = top card
        const order: number[] = cards.map((_, i) => i);

        const setZIndices = () => {
          order.forEach((cardIdx, slot) => {
            cards[cardIdx].style.zIndex = String(slot + 1);
          });
        };
        setZIndices();

        let touchStartX = 0;
        let touchStartY = 0;
        let isDragging  = false;
        let isAnimating = false;
        const THRESHOLD = 80;

        const snapBack = () => {
          const topCard = cards[order[order.length - 1]];
          topCard.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.2, 0.64, 1)';
          topCard.style.transform  = topCard.dataset.stack!;
          breatheEl.classList.remove('fanned');
        };

        stackEl.addEventListener('touchstart', (e: TouchEvent) => {
          if (isAnimating) return;
          touchStartX = e.touches[0].clientX;
          touchStartY = e.touches[0].clientY;
          isDragging  = false;
        }, { passive: true });

        stackEl.addEventListener('touchmove', (e: TouchEvent) => {
          if (isAnimating) return;
          const dx = e.touches[0].clientX - touchStartX;
          const dy = e.touches[0].clientY - touchStartY;

          // Let vertical scrolls pass through untouched
          if (!isDragging && Math.abs(dy) > Math.abs(dx)) return;

          isDragging = true;
          e.preventDefault();

          breatheEl.classList.add('fanned'); // pause breathing while dragging
          const topCard = cards[order[order.length - 1]];
          const rot = dx * 0.07;
          topCard.style.transition = 'none';
          topCard.style.transform  = `translate(${dx}px, ${Math.abs(dx) * 0.05}px) rotate(${rot}deg)`;
        }, { passive: false });

        stackEl.addEventListener('touchcancel', () => {
          if (!isDragging) return;
          isDragging = false;
          snapBack();
        }, { passive: true });

        stackEl.addEventListener('touchend', (e: TouchEvent) => {
          if (!isDragging) return;
          isDragging = false;

          const dx      = e.changedTouches[0].clientX - touchStartX;
          const topCard = cards[order[order.length - 1]];

          if (Math.abs(dx) >= THRESHOLD) {
            isAnimating = true;
            const dir   = dx > 0 ? 1 : -1;

            // Flick the card off screen
            topCard.style.transition = 'transform 0.36s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.36s ease';
            topCard.style.transform  = `translate(${dir * 520}px, 24px) rotate(${dir * 22}deg)`;
            topCard.style.opacity    = '0';

            setTimeout(() => {
              // Silently reset card, then move it to the bottom of the stack
              topCard.style.transition = 'none';
              topCard.style.transform  = topCard.dataset.stack!;
              topCard.style.opacity    = '1';

              // Cycle: top card becomes bottom card
              const popped = order.pop()!;
              order.unshift(popped);
              setZIndices();

              breatheEl.classList.remove('fanned');
              isAnimating = false;
            }, 400);
          } else {
            snapBack();
          }
        }, { passive: true });
      }
    }, 2600);
  });
</script>
