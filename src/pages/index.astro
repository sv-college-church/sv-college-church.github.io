---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Silicon Valley College Church"
  description="A contemporary Christian church in Silicon Valley for college students and young adults. Join us Sundays at 10am."
>
  <Nav />

  <main>
    <!-- HERO -->
    <section class="relative min-h-[92vh] flex items-center bg-paper pt-16 overflow-hidden">
      <!-- Decorative diagonal slashes (echo the logo motif) -->
      <div
        class="absolute right-0 top-0 w-px bg-ink/8 origin-top pointer-events-none"
        style="height: 140%; transform: rotate(8deg) translateX(-20vw);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute right-0 top-0 w-px bg-accent/20 origin-top pointer-events-none"
        style="height: 140%; transform: rotate(8deg) translateX(-22vw);"
        aria-hidden="true"
      ></div>

      <div class="max-w-6xl mx-auto px-6 py-24 w-full">
        <div class="max-w-3xl">
          <p
            class="font-sans text-xs font-semibold tracking-widest uppercase text-ink/40 mb-8 animate-fade-up"
            style="animation-delay: 0.1s"
          >
            Silicon Valley — Sundays 10 AM
          </p>

          <h1
            class="font-display font-semibold leading-[1.05] mb-8 animate-fade-up"
            style="font-size: clamp(3.5rem, 8vw, 7rem); animation-delay: 0.2s;"
          >
            A church<br />
            for the <span class="text-accent italic">curious.</span>
          </h1>

          <p
            class="font-sans text-lg text-ink/60 leading-relaxed max-w-xl mb-12 animate-fade-up"
            style="animation-delay: 0.35s"
          >
            We're a community of college students and young adults asking real questions,
            exploring faith, and finding belonging in Silicon Valley.
          </p>

          <div class="flex flex-wrap gap-4 animate-fade-up" style="animation-delay: 0.5s">
            <a
              href="#visit"
              class="font-sans font-semibold text-sm bg-ink text-paper px-8 py-4 hover:bg-accent transition-colors duration-200"
            >
              Plan a Visit
            </a>
            <a
              href="#connect"
              class="font-sans font-semibold text-sm border border-ink/20 text-ink px-8 py-4 hover:border-ink hover:bg-ink hover:text-paper transition-all duration-200"
            >
              Get Connected
            </a>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-6 flex items-center gap-3 animate-fade-up" style="animation-delay: 0.8s">
        <div class="w-px h-12 bg-ink/20"></div>
        <span class="font-sans text-xs text-ink/30 tracking-widest uppercase">Scroll</span>
      </div>
    </section>

    <!-- VISIT INFO STRIP -->
    <section id="visit" class="bg-ink text-paper py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 md:divide-x md:divide-paper/10">
          {[
            { label: 'When', value: 'Sundays', detail: '10:00 AM' },
            { label: 'Where', value: 'San Jose, CA', detail: 'Address shared upon RSVP' },
            { label: 'Who', value: 'Everyone', detail: 'College students & young adults' },
          ].map((item) => (
            <div class="md:px-8 first:pl-0 last:pr-0" data-animate>
              <p class="font-sans text-xs font-semibold tracking-widest uppercase text-paper/30 mb-2">{item.label}</p>
              <p class="font-display text-3xl font-semibold text-paper mb-1">{item.value}</p>
              <p class="font-sans text-sm text-paper/50">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHAT TO EXPECT -->
    <section class="py-24 bg-paper">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-16" data-animate>
          <p class="font-sans text-xs font-semibold tracking-widest uppercase text-ink/30 mb-3">First time?</p>
          <h2 class="font-display font-semibold leading-tight text-ink" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">
            What to expect
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink/8">
          {[
            { num: '01', title: 'Genuine welcome', body: 'No dress code, no obligation. Show up as you are. Someone will be there to greet you.' },
            { num: '02', title: 'Real teaching', body: 'We go through books of the Bible verse by verse. Challenging, honest, and worth your time.' },
            { num: '03', title: 'Community after', body: "Stick around. We hang out after service — it's genuinely the best part." },
          ].map((item, i) => (
            <div class="bg-paper p-10" data-animate data-animate-delay={String(i + 1)}>
              <span class="font-display text-5xl font-bold text-accent/20 block mb-6 leading-none">{item.num}</span>
              <h3 class="font-display text-2xl font-semibold text-ink mb-3">{item.title}</h3>
              <p class="font-sans text-sm text-ink/55 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO WE ARE -->
    <section class="py-24 bg-ink text-paper overflow-hidden relative">
      <div
        class="absolute left-0 top-0 w-px bg-paper/5 origin-top pointer-events-none"
        style="height: 130%; transform: rotate(6deg) translateX(30vw);"
        aria-hidden="true"
      ></div>

      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="max-w-2xl" data-animate>
          <p class="font-sans text-xs font-semibold tracking-widest uppercase text-paper/30 mb-4">Who we are</p>
          <h2 class="font-display font-semibold leading-tight mb-8" style="font-size: clamp(2rem, 4vw, 3.5rem);">
            We take the Bible seriously.<br />
            We take <span class="text-accent italic">questions</span> seriously too.
          </h2>
          <p class="font-sans text-base text-paper/60 leading-relaxed mb-10 max-w-lg">
            SVCC is a non-denominational church rooted in the gospel of Jesus Christ. We believe
            faith grows in community — so we prioritize belonging, honest conversation, and
            serving our city.
          </p>
          <a href="/about" class="inline-flex items-center gap-3 font-sans text-sm font-semibold text-paper hover:text-accent transition-colors">
            Read our story
            <span class="w-8 h-px bg-current inline-block"></span>
          </a>
        </div>
      </div>
    </section>

    <!-- GET CONNECTED -->
    <section id="connect" class="py-24 bg-paper">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div data-animate>
            <p class="font-sans text-xs font-semibold tracking-widest uppercase text-ink/30 mb-3">Next steps</p>
            <h2 class="font-display font-semibold leading-tight mb-6" style="font-size: clamp(2.5rem, 5vw, 4rem);">
              Ready to<br /><span class="text-accent italic">visit us?</span>
            </h2>
            <p class="font-sans text-sm text-ink/55 leading-relaxed max-w-sm">
              Fill out a quick form and we'll send you everything you need to know — address,
              parking, and what to expect — before you arrive.
            </p>
          </div>

          <div data-animate data-animate-delay="2">
            <form class="space-y-4" name="connect" method="POST" action="/thanks">
              <div>
                <label for="name" class="font-sans text-xs font-semibold tracking-wide uppercase text-ink/40 block mb-1.5">Your name</label>
                <input id="name" name="name" type="text" required placeholder="First name"
                  class="w-full border border-ink/15 bg-transparent px-4 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors" />
              </div>
              <div>
                <label for="email" class="font-sans text-xs font-semibold tracking-wide uppercase text-ink/40 block mb-1.5">Email</label>
                <input id="email" name="email" type="email" required placeholder="you@example.com"
                  class="w-full border border-ink/15 bg-transparent px-4 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors" />
              </div>
              <button type="submit"
                class="w-full bg-ink text-paper font-sans font-semibold text-sm py-4 hover:bg-accent transition-colors duration-200 mt-2">
                Send me the details
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fade-up 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
</style>
