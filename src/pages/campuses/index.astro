---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const campuses = [
  { name: 'San José State University', href: '/campuses/sjsu' },
  { name: 'Stanford', href: '/campuses/stanford' },
  { name: 'UC Santa Cruz', href: '/campuses/ucsc' },
  { name: 'Santa Clara University', href: '/campuses/scu' },
  { name: 'De Anza Community College', href: '/campuses/deanza' },
];
---

<BaseLayout title="Campuses" description="Campus ministries across Silicon Valley and beyond.">
  <Nav />

  <main class="campuses-main" style="padding-top: 5rem;">
    <section class="hero-section">
      <h1 class="page-title">Campuses</h1>
    </section>

    <div class="campus-list">
      {campuses.map((c) => (
        <a
          href={c.href}
          class="campus-name"
          style={`view-transition-name: campus-${c.href.split('/').pop()}`}
        >
          {c.name}
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .campuses-main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-section {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 3rem;
  }

  @media (min-width: 768px) {
    main { padding-top: 8rem !important; }
  }

  .page-title {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: clamp(3rem, 8vw, 8rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    color: rgb(10 10 10);
  }

  .campus-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem 2rem 3rem;
  }

  .campus-list:hover .campus-name {
    opacity: 0.15;
  }

  .campus-list:hover .campus-name:hover {
    opacity: 1;
  }

  .campus-name {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(10 10 10 / 0.8);
    text-decoration: none;
    line-height: 1.15;
    transition: opacity 0.3s ease, color 0.2s ease;
  }

  .campus-list:hover .campus-name:hover {
    color: rgb(10 10 10);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .campus-name { font-size: clamp(1.4rem, 6vw, 2.2rem); }
  }
</style>
