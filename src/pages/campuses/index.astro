---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const fellowships = [
  {
    name: 'Klesis',
    school: 'San José State University',
    shortSchool: 'SJSU',
    href: '/campuses/sjsu-klesis',
    logo: '/images/campuses/logos/klesis-sjsu.png',
  },
  {
    name: 'Moment',
    school: 'Stanford University',
    shortSchool: 'Stanford',
    href: '/campuses/stanford-moment',
    logo: '/images/campuses/logos/moment.png',
  },
  {
    name: 'Klesis',
    school: 'Santa Clara University',
    shortSchool: 'SCU',
    href: '/campuses/scu-klesis',
    logo: '/images/campuses/logos/klesis-scu.png',
  },
  {
    name: 'Klesis',
    school: 'UC Santa Cruz',
    shortSchool: 'UCSC',
    href: '/campuses/ucsc-klesis',
    logo: '/images/campuses/logos/klesis-ucsc.png',
  },
];

const international = [
  {
    name: '4Corners',
    school: 'San José State University',
    shortSchool: 'SJSU',
    href: '/campuses/sjsu-4c',
    logo: '/images/campuses/logos/4corners.png',
  },
  {
    name: 'Moment International',
    school: 'Stanford University',
    shortSchool: 'Stanford',
    href: '/campuses/stanford-moment#international',
    logo: '/images/campuses/logos/moment-intl.png',
  },
  {
    name: 'ISMP',
    school: 'De Anza College',
    shortSchool: 'De Anza',
    href: 'https://internationalmentorship.org/deanza',
    external: true,
    logo: '/images/campuses/logos/ismp.png',
  },
  {
    name: 'ISMP',
    school: 'San José State University',
    shortSchool: 'SJSU',
    href: 'https://internationalmentorship.org/sjsu',
    external: true,
    logo: '/images/campuses/logos/ismp.png',
  },
];
---

<BaseLayout title="Campuses" description="Campus ministries across Silicon Valley and beyond.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Hero -->
    <section class="px-6 py-16 text-center md:py-28">
      <h1 class="font-sans font-black uppercase leading-none text-ink" style="font-size: clamp(3rem, 8vw, 8rem);">
        Campuses
      </h1>
      <p class="col-body mx-auto mt-8 max-w-2xl">
        Our college students are part of Christian fellowships on campuses across Silicon Valley. Each fellowship is a community rooted in the Acts 2 church — studying the Bible, sharing meals, and doing life together.
      </p>
    </section>

    <!-- Fellowship -->
    <section class="border-t border-ink/15 px-6 py-20 md:px-16" data-animate>
      <h2 class="col-label mb-12">Fellowship</h2>
      <div class="campus-grid">
        {fellowships.map((f) => (
          <a href={f.href} class="campus-cell" aria-label={`Learn more about ${f.name} at ${f.shortSchool}`}>
            <img src={f.logo} alt={`${f.name} logo`} class="campus-logo" />
            <h3 class="campus-name">{f.name}</h3>
            <p class="campus-school">{f.school}</p>
            <p class="campus-link">Learn more →</p>
          </a>
        ))}
      </div>
    </section>

    <!-- International Ministries -->
    <section class="border-t border-ink/15 px-6 py-20 md:px-16" data-animate>
      <h2 class="col-label mb-12">International Ministries</h2>
      <div class="campus-grid">
        {international.map((f) => (
          <a
            href={f.href}
            class="campus-cell"
            aria-label={f.external ? `Visit ${f.name} at ${f.shortSchool} website` : `Learn more about ${f.name} at ${f.shortSchool}`}
            {...(f.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <img src={f.logo} alt={`${f.name} logo`} class="campus-logo" />
            <h3 class="campus-name">{f.name}</h3>
            <p class="campus-school">{f.school}</p>
            <p class="campus-link">{f.external ? 'Visit site ↗' : 'Learn more →'}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-ink/15 px-6 py-16 text-center md:px-16" data-animate>
      <p class="col-body">Want to get plugged in?</p>
      <a
        href="/connect"
        class="mt-6 inline-block border border-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
      >
        Get Connected
      </a>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .col-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(20 20 20 / 0.35);
  }

  .col-body {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.75;
    color: rgb(20 20 20 / 0.65);
  }

  .campus-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .campus-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .campus-cell {
    display: flex;
    flex-direction: column;
    padding: 2.5rem 0;
    border-top: 1px solid rgb(20 20 20 / 0.1);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .campus-cell:hover {
    opacity: 0.7;
  }

  .campus-cell:hover .campus-logo {
    filter: grayscale(0%);
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    .campus-cell {
      padding: 2.5rem 3rem 2.5rem 0;
    }

    .campus-cell:nth-child(even) {
      padding-left: 3rem;
      padding-right: 0;
      border-left: 1px solid rgb(20 20 20 / 0.1);
    }
  }

  .campus-logo {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
    margin-bottom: 1.25rem;
    filter: grayscale(100%);
    opacity: 0.5;
    transition: filter 0.3s, opacity 0.3s;
  }

  .campus-name {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(20 20 20);
  }

  .campus-school {
    font-size: 0.7rem;
    color: rgb(20 20 20 / 0.4);
    letter-spacing: 0.02em;
    margin-top: 0.35rem;
  }

  .campus-link {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #D91C2A;
    margin-top: 1rem;
  }
</style>
