---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const campuses = [
  { name: 'San José State University', href: '/campuses/sjsu' },
  { name: 'Stanford', href: '/campuses/stanford' },
  { name: 'UC Santa Cruz', href: '/campuses/ucsc' },
  { name: 'Santa Clara University', href: '/campuses/scu' },
  { name: 'De Anza College', href: '/campuses/deanza' },
];
---

<BaseLayout title="Campuses | Silicon Valley College Church" description="SVC campus ministries at Stanford, San José State, Santa Clara University, UC Santa Cruz, and De Anza College.">
  <Nav />

  <main class="campuses-main" style="padding-top: 5rem;">
    <section class="hero-section">
      <h1 class="page-title">Campuses</h1>
    </section>

    <div class="campus-list">
      {campuses.map((c) => (
        <a
          href={c.href}
          class="campus-name"
          style={`view-transition-name: campus-${c.href.split('/').pop()}`}
        >
          {c.name}
        </a>
      ))}
    </div>

    <!-- Class of 2030 badge -->
    <a href="/class-of-2030" id="class-badge" aria-label="Class of 2030 — welcome">
      <div class="badge-ring" aria-hidden="true">
        <span style="--a:0">✦</span>
        <span style="--a:24">W</span>
        <span style="--a:36">E</span>
        <span style="--a:48">L</span>
        <span style="--a:60">C</span>
        <span style="--a:72">O</span>
        <span style="--a:84">M</span>
        <span style="--a:96">E</span>
        <span style="--a:120">✦</span>
        <span style="--a:144">W</span>
        <span style="--a:156">E</span>
        <span style="--a:168">L</span>
        <span style="--a:180">C</span>
        <span style="--a:192">O</span>
        <span style="--a:204">M</span>
        <span style="--a:216">E</span>
        <span style="--a:240">✦</span>
        <span style="--a:264">W</span>
        <span style="--a:276">E</span>
        <span style="--a:288">L</span>
        <span style="--a:300">C</span>
        <span style="--a:312">O</span>
        <span style="--a:324">M</span>
        <span style="--a:336">E</span>
      </div>
      <div class="badge-center-content">
        <span class="badge-classof">CLASS</span>
        <span class="badge-dot">·</span>
        <span class="badge-year-num">2030</span>
      </div>
    </a>

  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Campuses page: fill the viewport, but allow scrolling on short viewports */
  body {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  .campuses-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .hero-section {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 3rem;
  }

  @media (min-width: 768px) {
    main { padding-top: 8rem !important; }
  }

  @media (min-width: 768px) and (max-height: 760px) {
    main { padding-top: 5rem !important; }
  }

  .page-title {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: clamp(3rem, 8vw, 8rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    color: rgb(10 10 10);
  }

  .campus-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem 2rem 3rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .campus-list:hover .campus-name {
      opacity: 0.15;
    }

    .campus-list:hover .campus-name:hover {
      opacity: 1;
    }
  }

  .campus-name {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(10 10 10 / 0.8);
    text-decoration: none;
    line-height: 1.15;
    transition: opacity 0.3s ease, color 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .campus-list:hover .campus-name:hover {
      color: rgb(10 10 10);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .campus-list { gap: 1.25rem; }
    .campus-name { font-size: clamp(1.4rem, 6vw, 2.2rem); }
  }

  /* ── Class of 2030 Badge ── */
  #class-badge {
    --ring-r: -65px;
    position: absolute;
    top: 148px;
    right: 5%;
    width: 172px;
    height: 172px;
    border-radius: 50%;
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    z-index: 20;
    opacity: 0;
    cursor: pointer;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.3),
      0 0 0 0px rgba(217, 28, 42, 0);
  }

  #class-badge::before {
    content: '';
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px solid rgba(245, 245, 240, 0.12);
    pointer-events: none;
  }

  #class-badge::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid rgba(217, 28, 42, 0.55);
    opacity: 0;
    pointer-events: none;
  }

  #class-badge.is-live {
    animation: badgePopIn 0.65s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
  }

  #class-badge.is-breathing {
    opacity: 1;
    transform: scale(1);
    animation: badgeBreathe 2.8s ease-in-out infinite;
    transition: transform 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  #class-badge:hover {
    transform: scale(1.13) !important;
  }

  #class-badge.is-breathing::after {
    animation: badgePulseRing 2.8s ease-out infinite;
  }

  @keyframes badgePopIn {
    0%   { opacity: 0; transform: scale(0.72) rotate(-8deg); }
    65%  { opacity: 1; transform: scale(1.08) rotate(2deg); }
    82%  { transform: scale(0.97) rotate(0deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes badgeBreathe {
    0%, 100% {
      box-shadow:
        0 4px 20px rgba(0, 0, 0, 0.3),
        0 0 0 0px rgba(217, 28, 42, 0.45);
    }
    50% {
      box-shadow:
        0 6px 32px rgba(0, 0, 0, 0.2),
        0 0 0 14px rgba(217, 28, 42, 0);
    }
  }

  @keyframes badgePulseRing {
    0%   { opacity: 0.65; transform: scale(1); }
    100% { opacity: 0;    transform: scale(1.4); }
  }

  @keyframes badgeRingRotate {
    to { transform: rotate(360deg); }
  }

  .badge-ring {
    position: absolute;
    inset: 0;
    animation: badgeRingRotate 18s linear infinite;
  }

  .badge-ring span {
    position: absolute;
    left: 50%;
    top: 50%;
    margin: -0.5em 0 0 -0.5em;
    width: 1em;
    height: 1em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #F5F5F0;
    text-transform: uppercase;
    line-height: 1;
    transform-origin: center center;
    transform: rotate(calc(var(--a) * 1deg)) translateY(var(--ring-r, -65px));
  }

  .badge-center-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    pointer-events: none;
    user-select: none;
  }

  .badge-classof {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(245, 245, 240, 0.6);
    text-transform: uppercase;
  }

  .badge-dot {
    color: #D91C2A;
    font-size: 18px;
    line-height: 0.8;
  }

  .badge-year-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 30px;
    font-weight: 700;
    font-style: italic;
    color: #F5F5F0;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  @media (max-width: 767px) {
    #class-badge {
      --ring-r: -48px;
      width: 120px;
      height: 120px;
      top: auto;
      bottom: 6%;
      right: 5%;
    }
    .badge-year-num { font-size: 20px; }
    .badge-dot { font-size: 13px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const badge = document.getElementById('class-badge');
    if (!badge) return;
    badge.classList.remove('is-live', 'is-breathing');
    setTimeout(() => {
      badge.classList.add('is-live');
      setTimeout(() => badge.classList.add('is-breathing'), 1100);
    }, 400);
  });
</script>
