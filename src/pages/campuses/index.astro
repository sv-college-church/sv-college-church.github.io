---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const schools = [
  {
    id: 'sjsu',
    label: 'San José State',
    name: 'SJSU',
    href: '/campuses/sjsu',
  },
  {
    id: 'stanford',
    label: 'Stanford University',
    name: 'Stanford',
    href: '/campuses/stanford',
  },
  {
    id: 'ucsc',
    label: 'UC Santa Cruz',
    name: 'UCSC',
    href: '/campuses/ucsc',
  },
];
---

<BaseLayout title="Campuses" description="Campus ministries across Silicon Valley and beyond.">
  <Nav />

  <main class="campuses-main">
    <div class="triptych">
      {schools.map((school) => (
        <a
          href={school.href}
          class="campus-col"
          aria-label={`Learn more about ${school.label}`}
          style={`view-transition-name: campus-${school.id}`}
        >
          <p class="col-label">{school.label}</p>
          <h2 class="col-name">{school.name}</h2>
          <span class="col-cta">Learn More →</span>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .campuses-main {
    min-height: 100svh;
    display: flex;
    align-items: stretch;
    padding-top: 5rem; /* clear nav */
  }

  .triptych {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    width: 100%;
  }

  .campus-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 3rem;
    text-decoration: none;
    color: inherit;
  }

  .campus-col:not(:last-child) {
    border-right: 1px solid rgb(10 10 10 / 0.1);
  }

  .campus-col:hover .col-name {
    color: rgb(10 10 10);
  }

  .campus-col:hover .col-cta {
    color: rgb(10 10 10 / 0.7);
  }

  .col-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(10 10 10 / 0.32);
    margin-bottom: 1.5rem;
  }

  .col-name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2.5rem, 4.5vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: rgb(10 10 10 / 0.75);
    margin-bottom: 2.5rem;
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  .col-cta {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgb(10 10 10 / 0.35);
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .campuses-main {
      padding-top: 4rem;
      min-height: unset;
    }

    .triptych {
      grid-template-columns: 1fr;
    }

    .campus-col {
      padding: 3.5rem 2rem;
    }

    .campus-col:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid rgb(10 10 10 / 0.1);
    }

    .col-name {
      font-size: clamp(3rem, 14vw, 5rem);
      white-space: normal;
    }
  }
</style>
