---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import momentLogo from '../../assets/images/campuses/logos/moment.png';
import momentIntl from '../../assets/images/campuses/logos/moment-intl.png';
---

<BaseLayout title="Stanford | Silicon Valley College Church" description="Silicon Valley College Church at Stanford University — campus ministry for Stanford students in Palo Alto.">
  <Nav />

  <main>

    <section class="hero-section" style="view-transition-name: campus-stanford">
      <a href="/campuses" class="back-link">← Campuses</a>
      <h1 class="school-name">Stanford<br/>University</h1>
      <a href="#" class="mentor-btn">Meet the Mentors</a>
    </section>

    <section class="groups-section">
      <div class="group-col">
        <Image src={momentLogo} alt="Moment Stanford" class="group-logo" />
        <p class="group-label">Moment · Stanford</p>
        <p class="group-body">A Christian fellowship for Stanford students built around community, Bible study, and discipleship. Modeled after the Acts 2 church and open to all.</p>
        <a href="https://www.instagram.com/moment.stanford/" target="_blank" rel="noopener noreferrer" class="group-link">Events ↗</a>
      </div>
      <div class="col-divider" aria-hidden="true"></div>
      <div class="group-col">
        <Image src={momentIntl} alt="Moment International" class="group-logo" />
        <p class="group-label">Moment International · Stanford</p>
        <p class="group-body">Moment International reaches international students at Stanford with the gospel — a community for those navigating a new country and a new chapter of life.</p>
        <a href="https://www.instagram.com/moment.intl/" target="_blank" rel="noopener noreferrer" class="group-link">Events ↗</a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style is:global>
  html, body { background: #6B0F0F !important; }
  body { display: flex; flex-direction: column; min-height: 100svh; }

  header {
    background: rgba(90, 10, 10, 0.97) !important;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  header a { color: rgba(255,255,255,0.75) !important; }
  header a:hover { color: #ffffff !important; }
  .hamburger-bar { background-color: rgba(255,255,255,0.8) !important; }
  .logo-main, .logo-depth { filter: invert(1) brightness(1.1) !important; }

  #mobile-menu nav {
    background: #5A0A0A !important;
    border-color: rgba(255,255,255,0.08) !important;
  }
  #mobile-menu a {
    color: rgba(255,255,255,0.75) !important;
    border-color: rgba(255,255,255,0.08) !important;
  }

  footer {
    background: #5A0A0A !important;
    border-color: rgba(255,255,255,0.1) !important;
  }
  footer p { color: rgba(255,255,255,0.3) !important; }
  footer a { color: rgba(255,255,255,0.3) !important; }
  footer a:hover { color: rgba(255,255,255,0.7) !important; }
  footer .network-logo { filter: none !important; }
</style>

<style>
  main { flex: 1; display: flex; flex-direction: column; }

  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 40vh;
    padding: 12rem 2rem 4rem;
    position: relative;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .back-link {
    position: absolute;
    top: 9rem;
    left: 2rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #ffffff; }

  .school-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(2rem, 6vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #ffffff;
  }

  .mentor-btn {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #6B0F0F;
    background: #ffffff;
    text-decoration: none;
    padding: 0.75rem 2.25rem;
    margin-top: 2rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .mentor-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }

  .groups-section {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
  }

  .col-divider {
    background: rgba(255,255,255,0.1);
    align-self: stretch;
  }

  .group-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 3rem;
    gap: 1.25rem;
  }

  .group-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    opacity: 0.55;
    filter: invert(1);
    margin-bottom: 0.25rem;
  }

  .group-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.75);
  }

  .group-body {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    font-weight: 500;
    line-height: 1.8;
    color: rgba(255,255,255,0.6);
    max-width: 36ch;
  }

  .group-link {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #6B0F0F;
    background: #ffffff;
    text-decoration: none;
    padding: 0.75rem 2.25rem;
    margin-top: 0.75rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .group-link:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }

  @media (max-width: 640px) {
    .groups-section {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1px auto;
    }
    .col-divider {
      width: 100%;
      height: 1px;
    }
    .group-col { padding: 3.5rem 2rem; }
  }
</style>
