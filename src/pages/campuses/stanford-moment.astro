---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Moment — Stanford" description="Moment Christian Fellowship at Stanford University.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Hero -->
    <section class="px-6 py-16 text-center md:py-28">
      <p class="col-label mb-4">Stanford University</p>
      <h1 class="font-sans font-black uppercase leading-none text-ink" style="font-size: clamp(2.5rem, 7vw, 7rem);">
        Moment
      </h1>
      <div class="mt-10 flex items-center justify-center gap-6">
        <a
          href="/connect"
          class="border border-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
        >
          Get Connected
        </a>
        <a
          href="https://momentfellowship.org"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-paper transition-colors duration-200 hover:bg-ink/70"
        >
          Visit Site ↗
        </a>
      </div>
    </section>

    <!-- Photo -->
    <section class="w-full px-6 md:px-16" data-animate>
      <img
        src="/images/campuses/stanford-moment.jpg"
        alt="Moment Christian Fellowship at Stanford group photo"
        class="hero-photo"
      />
    </section>

    <!-- Info grid -->
    <section class="w-full border-t border-ink/15 mt-16" data-animate>
      <div class="info-grid">
        <div class="info-col">
          <p class="col-label">Who We Are</p>
          <p class="col-body">
            Moment is an official campus student ministry at Stanford. We're all about connecting with God and each other during our college years and beyond.
          </p>
          <p class="col-body">
            We want college students everywhere to experience what we experienced in college. Many of us weren't Christians growing up but became convinced Christianity is true in college. Others grew up religious, but didn't find God or the Bible relevant until we were college students. But all of us encountered God personally and were transformed as we experienced life as He intended — closely connected to Him and to others.
          </p>
          <p class="col-body">
            Being in college — that season of life when you're figuring out who you are and what you're doing with your life — was a key part of our spiritual journey. And we hope it will be for yours, too.
          </p>
        </div>
        <div class="info-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Sundays ⛪</p>
          <p class="col-display">12 PM<br />at SVC</p>
          <p class="col-body">
            Rides at 11:00 AM from Tresidder Memorial Union.
          </p>
        </div>
        <div class="info-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Status</p>
          <p class="col-body">
            <a href="https://cardinalengage.stanford.edu/club_signup?group_type=&search=moment&category_tags=&order=name_asc" target="_blank" rel="noopener noreferrer" class="text-link">Official campus student ministry</a> at Stanford.
          </p>
        </div>
      </div>
    </section>

    <!-- International Connect Group -->
    <section id="international" class="border-t border-ink/15 px-6 py-20 md:px-16" data-animate>
      <p class="col-label mb-12">International Connect Group</p>
      <div class="intl-row">
        <div class="intl-photo-wrap">
          <img src="/images/campuses/stanford-moment-intl.jpg" alt="Moment International Connect Group welcome night" class="intl-photo" />
        </div>
        <div class="intl-bio">
          <p class="col-body">
            Moment started off as a Christian fellowship for mainly undergrads. But we have recently also launched an International Grad Connect Group! Our vision is to create a place where people from different cultures and diverse backgrounds can come together to experience God and journey alongside each other.
          </p>
          <p class="col-body mt-4">
            Along the way we also hang out, eat good food, go on awesome trips, and just do life together. At our Grad Connect Group, we try to recreate the church we read in Acts chapter 2 of the Bible — ordinary folks forming an extraordinary community — and we invite you to join us!
          </p>
        </div>
      </div>
    </section>

    <!-- Back link -->
    <section class="border-t border-ink/15 px-6 py-12 md:px-16">
      <a href="/campuses" class="back-link">← All Campuses</a>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .col-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(20 20 20 / 0.35);
  }

  .col-body {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.75;
    color: rgb(20 20 20 / 0.65);
  }

  .col-display {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: rgb(20 20 20);
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    object-position: center;
    border: 1.5px solid rgb(20 20 20 / 0.15);
    background: rgb(20 20 20 / 0.04);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .info-col {
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .info-col {
      padding: 3rem 3.5rem;
    }
  }

  .text-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(20 20 20 / 0.3);
    transition: text-decoration-color 0.2s;
  }

  .text-link:hover {
    text-decoration-color: rgb(20 20 20);
  }

  .intl-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .intl-row {
      grid-template-columns: 2fr 3fr;
      gap: 6rem;
      align-items: start;
    }
  }

  .intl-photo {
    width: 100%;
    aspect-ratio: 3 / 2;
    border: 1.5px solid rgb(20 20 20 / 0.15);
    background: rgb(20 20 20 / 0.04);
    object-fit: cover;
    object-position: center;
  }

  .intl-bio {
    display: flex;
    flex-direction: column;
  }

  .back-link {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(20 20 20 / 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: rgb(20 20 20);
  }
</style>
