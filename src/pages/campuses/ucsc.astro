---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import klesisUcsc from '../../assets/images/campuses/logos/klesis-ucsc.png';
---

<BaseLayout title="UCSC — Campuses" description="Campus ministries at UC Santa Cruz.">
  <Nav />

  <main>

    <section class="hero-section" style="view-transition-name: campus-ucsc">
      <a href="/campuses" class="back-link">← Campuses</a>
      <h1 class="school-name">UC Santa Cruz</h1>
    </section>

    <section class="group-section">
      <Image src={klesisUcsc} alt="Klesis UCSC" class="group-logo" />
      <p class="group-label">Klesis · UC Santa Cruz</p>
      <p class="group-body">Klesis UC Santa Cruz is a Christian fellowship for UCSC students built on Bible study, community, and doing life together. Modeled after the Acts 2 church and open to all students.</p>
      <a href="https://heywhatsup.app/groups/klesis-at-ucsc" target="_blank" rel="noopener noreferrer" class="group-link">Events ↗</a>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style is:global>
  html, body { background: #002A4E !important; }
  body { display: flex; flex-direction: column; min-height: 100svh; }

  header {
    background: rgba(0, 36, 68, 0.97) !important;
    border-bottom: 1px solid rgba(253,199,0,0.15);
  }
  header a { color: rgba(255,255,255,0.75) !important; }
  header a:hover { color: #FDC700 !important; }
  .hamburger-bar { background-color: rgba(255,255,255,0.8) !important; }
  .logo-main, .logo-depth { filter: invert(1) brightness(1.1) !important; }

  #mobile-menu nav {
    background: #001F3A !important;
    border-color: rgba(253,199,0,0.12) !important;
  }
  #mobile-menu a {
    color: rgba(255,255,255,0.75) !important;
    border-color: rgba(255,255,255,0.08) !important;
  }

  footer {
    background: #001F3A !important;
    border-color: rgba(253,199,0,0.15) !important;
  }
  footer p { color: rgba(253,199,0,0.35) !important; }
  footer a { color: rgba(253,199,0,0.35) !important; }
  footer a:hover { color: rgba(253,199,0,0.85) !important; }
  footer .network-logo { filter: none !important; }
</style>

<style>
  main { flex: 1; display: flex; flex-direction: column; }

  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 40vh;
    padding: 12rem 2rem 4rem;
    position: relative;
    border-bottom: 1px solid rgba(253,199,0,0.15);
  }

  .back-link {
    position: absolute;
    top: 9rem;
    left: 2rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(253,199,0,0.45);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #FDC700; }

  .school-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(2rem, 6vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #FDC700;
  }

  .group-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 2rem 6rem;
    gap: 1.25rem;
  }

  .group-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    opacity: 0.55;
    filter: invert(1);
    margin-bottom: 0.25rem;
  }

  .group-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(253,199,0,0.9);
  }

  .group-body {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    font-weight: 500;
    line-height: 1.8;
    color: rgba(255,255,255,0.65);
    max-width: 44ch;
  }

  .group-link {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #002A4E;
    background: #FDC700;
    text-decoration: none;
    padding: 0.75rem 2.25rem;
    margin-top: 0.75rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .group-link:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }
</style>
