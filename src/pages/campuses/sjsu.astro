---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import klesisSjsu from '../../assets/images/campuses/logos/klesis-sjsu.png';
import fourCorners from '../../assets/images/campuses/logos/4corners.png';
---

<BaseLayout title="San José State | Silicon Valley College Church" description="Silicon Valley College Church at San José State University — campus ministry for SJSU students in San Jose.">
  <Nav />

  <main>

    <section class="hero-section" style="view-transition-name: campus-sjsu">
      <a href="/campuses" class="back-link">← Campuses</a>
      <h1 class="school-name">San José State<br/>University</h1>
    </section>

    <section class="groups-section">
      <div class="group-col">
        <Image src={klesisSjsu} alt="Klesis SJSU" class="group-logo" />
        <p class="group-label">Klesis · SJSU</p>
        <p class="group-body">Klesis SJSU is a place for friendships, purpose, sports, nerf battles, investigating the Christian faith, and being there for one another. Modeled after the Acts 2 church and open to all students regardless of background.</p>
        <a href="https://www.instagram.com/klesis.sjsu/" target="_blank" rel="noopener noreferrer" class="group-link">Events ↗</a>
      </div>
      <div class="col-divider" aria-hidden="true"></div>
      <div class="group-col">
        <Image src={fourCorners} alt="4Corners" class="group-logo" />
        <p class="group-label">4Corners · SJSU</p>
        <p class="group-body">4Corners is a fellowship for international students at SJSU — a place to find community, explore the Christian faith, and feel at home in a new country. Open to all international and domestic students.</p>
        <a href="https://www.instagram.com/4corners.sjsu/" target="_blank" rel="noopener noreferrer" class="group-link">Events ↗</a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style is:global>
  html, body { background: #003874 !important; }
  body { display: flex; flex-direction: column; min-height: 100svh; }

  header {
    border-bottom: 1px solid rgba(229, 168, 35, 0.15);
  }
  header::before {
    background: rgba(0, 40, 100, 0.96) !important;
  }
  header a { color: rgba(255,255,255,0.75) !important; }
  header a:hover { color: #E5A823 !important; }
  .hamburger-bar { background-color: rgba(255,255,255,0.8) !important; }
  .logo-main, .logo-depth { filter: invert(1) brightness(1.1) !important; }

  #mobile-menu nav {
    background: #002D6B !important;
    border-color: rgba(229, 168, 35, 0.15) !important;
  }
  #mobile-menu a {
    color: rgba(255,255,255,0.75) !important;
    border-color: rgba(255,255,255,0.08) !important;
  }

  footer {
    background: #002D6B !important;
    border-color: rgba(229, 168, 35, 0.15) !important;
  }
  footer p { color: rgba(229,168,35,0.65) !important; }
  footer a { color: rgba(229,168,35,0.65) !important; }
  footer a:hover { color: rgba(229,168,35,0.9) !important; }
  footer .network-logo { filter: none !important; }
</style>

<style>
  main { flex: 1; display: flex; flex-direction: column; }

  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 40vh;
    padding: 12rem 2rem 4rem;
    position: relative;
    border-bottom: 1px solid rgba(229, 168, 35, 0.15);
  }

  .back-link {
    position: absolute;
    top: 9rem;
    left: 2rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(229, 168, 35, 0.85);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #E5A823; }

  .school-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(2rem, 6vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #E5A823;
  }

  .groups-section {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
  }

  .col-divider {
    background: rgba(229, 168, 35, 0.15);
    align-self: stretch;
  }

  .group-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 3rem;
    gap: 1.25rem;
  }

  .group-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    opacity: 0.55;
    filter: invert(1);
    margin-bottom: 0.25rem;
  }

  .group-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(229, 168, 35, 0.9);
  }

  .group-body {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    font-weight: 500;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.65);
    max-width: 36ch;
  }

  .group-link {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #003874;
    background: #E5A823;
    text-decoration: none;
    padding: 0.75rem 2.25rem;
    margin-top: 0.75rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .group-link:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }

  @media (max-width: 640px) {
    .groups-section {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1px auto;
    }
    .col-divider {
      width: 100%;
      height: 1px;
    }
    .group-col { padding: 3.5rem 2rem; }
  }
</style>
