---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Klesis SCU" description="Klesis Christian Fellowship at Santa Clara University.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Hero -->
    <section class="px-6 py-16 text-center md:py-28">
      <p class="col-label mb-4">Santa Clara University</p>
      <h1 class="font-sans font-black uppercase leading-none text-ink" style="font-size: clamp(2.5rem, 7vw, 7rem);">
        Klesis
      </h1>
      <div class="mt-10 flex items-center justify-center gap-6">
        <a
          href="/connect"
          class="border border-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
        >
          Get Connected
        </a>
        <a
          href="https://scu.klesis.org"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-ink px-8 py-3 font-sans text-sm font-bold uppercase tracking-widest text-paper transition-colors duration-200 hover:bg-ink/70"
        >
          Visit Site ↗
        </a>
      </div>
    </section>

    <!-- Photo -->
    <section class="w-full px-6 md:px-16" data-animate>
      <img
        src="/images/campuses/scu-klesis.jpg"
        alt="Klesis SCU group photo"
        class="hero-photo"
      />
    </section>

    <!-- Info grid -->
    <section class="w-full border-t border-ink/15 mt-16" data-animate>
      <div class="info-grid">
        <div class="info-col">
          <p class="col-label">Who We Are</p>
          <p class="col-body">
            Klesis Christian Fellowship is a registered student organization open to all Santa Clara University students. We're all about connecting with God and each other during our college journeys and beyond.
          </p>
        </div>
        <div class="info-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Sundays ⛪</p>
          <p class="col-display">12 PM<br />at SVC</p>
          <p class="col-body">
            Rides at 11:30 AM from the Bronco Statue.
          </p>
        </div>
        <div class="info-col border-t border-ink/15 md:border-l md:border-t-0">
          <p class="col-label">Instagram</p>
          <p class="col-body">
            <a href="https://www.instagram.com/klesis.scu/" target="_blank" rel="noopener noreferrer" class="text-link">@klesis.scu</a>
          </p>
        </div>
      </div>
    </section>

    <!-- What We Do -->
    <section class="border-t border-ink/15 px-6 py-20 md:px-16" data-animate>
      <p class="col-label mb-12">What We Do</p>
      <div class="activities-grid">
        <div class="activity">
          <h3 class="activity-title">Weekly Fellowship</h3>
          <p class="col-body">We gather weekly for community, worship, and Bible study — building friendships and growing in faith together on campus.</p>
        </div>
        <div class="activity">
          <h3 class="activity-title">Sunday Service</h3>
          <p class="col-body">We attend Silicon Valley College Church on Sundays. Rides leave at 11:30 AM from the Bronco Statue.</p>
          <p class="activity-detail">2346 Walsh Ave, Santa Clara, CA 95051</p>
        </div>
        <div class="activity">
          <h3 class="activity-title">Discipleship</h3>
          <p class="col-body">We have discipleship groups connecting college students across SCU, SJSU, UC Santa Cruz, Stanford, and De Anza.</p>
        </div>
        <div class="activity">
          <h3 class="activity-title">Community</h3>
          <p class="col-body">Sports, meals, outings, and hangouts — we do life together and build lasting friendships along the way.</p>
        </div>
      </div>
    </section>

    <!-- Back link -->
    <section class="border-t border-ink/15 px-6 py-12 md:px-16">
      <a href="/campuses" class="back-link">← All Campuses</a>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .col-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(20 20 20 / 0.35);
  }

  .col-body {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.75;
    color: rgb(20 20 20 / 0.65);
  }

  .col-display {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: rgb(20 20 20);
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    object-position: center;
    border: 1.5px solid rgb(20 20 20 / 0.15);
    background: rgb(20 20 20 / 0.04);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .info-col {
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .info-col {
      padding: 3rem 3.5rem;
    }
  }

  .text-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(20 20 20 / 0.3);
    transition: text-decoration-color 0.2s;
  }

  .text-link:hover {
    text-decoration-color: rgb(20 20 20);
  }

  .activities-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .activities-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .activity {
    padding: 2.5rem 0;
    border-top: 1px solid rgb(20 20 20 / 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .activity {
      padding: 2.5rem 3rem 2.5rem 0;
    }

    .activity:nth-child(even) {
      padding-left: 3rem;
      padding-right: 0;
      border-left: 1px solid rgb(20 20 20 / 0.1);
    }
  }

  .activity-title {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(20 20 20);
  }

  .activity-detail {
    font-size: 0.7rem;
    color: rgb(20 20 20 / 0.3);
    letter-spacing: 0.02em;
    margin-top: 0.25rem;
  }

  .back-link {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(20 20 20 / 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: rgb(20 20 20);
  }
</style>
