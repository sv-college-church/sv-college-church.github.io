---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import ismpLogo from '../../assets/images/campuses/logos/ismp.png';
---

<BaseLayout title="De Anza | Silicon Valley College Church" description="Silicon Valley College Church at De Anza College — campus ministry for De Anza students in Cupertino.">
  <Nav />

  <main>

    <section class="hero-section" style="view-transition-name: campus-deanza">
      <a href="/campuses" class="back-link">← Campuses</a>
      <Image src={ismpLogo} alt="ISMP" class="hero-logo" />
      <p class="hero-fellowship">ISMP</p>
      <h1 class="school-name">De Anza<br/>Community College</h1>
      <a href="#" class="mentor-btn">Meet the Mentors</a>
    </section>

    <section class="info-grid">
      <div class="info-col">
        <h2 class="info-label">Established</h2>
        <p class="info-value">2015</p>
      </div>
      <div class="info-col">
        <h2 class="info-label">About</h2>
        <p class="info-value">Coming soon</p>
      </div>
      <div class="info-col">
        <h2 class="info-label">Events</h2>
        <a href="https://internationalmentorship.org/deanza" target="_blank" rel="noopener noreferrer" class="events-btn">ISMP ↗</a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style is:global>
  html, body { background: #2E0E0E !important; }
  body { display: flex; flex-direction: column; min-height: 100svh; }

  header {
    background: rgba(36, 8, 8, 0.97) !important;
    border-bottom: 1px solid rgba(196,160,50,0.2);
  }
  header a { color: rgba(255,255,255,0.7) !important; }
  header a:hover { color: #C4A032 !important; }
  .hamburger-bar { background-color: rgba(255,255,255,0.8) !important; }
  .logo-main, .logo-depth { filter: invert(1) brightness(1.1) !important; }

  #mobile-menu nav {
    background: #240808 !important;
    border-color: rgba(196,160,50,0.15) !important;
  }
  #mobile-menu a {
    color: rgba(255,255,255,0.7) !important;
    border-color: rgba(255,255,255,0.08) !important;
  }

  footer {
    background: #240808 !important;
    border-color: rgba(196,160,50,0.2) !important;
  }
  footer p { color: rgba(196,160,50,0.35) !important; }
  footer a { color: rgba(196,160,50,0.35) !important; }
  footer a:hover { color: rgba(196,160,50,0.85) !important; }
  footer .network-logo { filter: none !important; }
</style>

<style>
  main { flex: 1; display: flex; flex-direction: column; }

  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 40vh;
    padding: 12rem 2rem 4rem;
    position: relative;
  }

  .back-link {
    position: absolute;
    top: 9rem;
    left: 2rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(196,160,50,0.45);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #C4A032; }

  .hero-logo {
    height: 90px;
    width: auto;
    object-fit: contain;
    opacity: 0.45;
    filter: invert(1);
    margin-bottom: 0.5rem;
  }

  .hero-fellowship {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1.25rem;
  }

  .school-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(2rem, 6vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #C4A032;
  }

  .mentor-btn {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #2E0E0E;
    background: #C4A032;
    text-decoration: none;
    padding: 0.75rem 2.25rem;
    margin-top: 2rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .mentor-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }

  .info-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: 1rem 3rem 6rem;
  }

  .info-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 2rem;
    gap: 1rem;
  }

  .info-label {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: #C4A032;
    margin: 0;
  }

  .info-value {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1;
    color: #ffffff;
  }

  .events-btn {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #2E0E0E;
    background: #C4A032;
    text-decoration: none;
    padding: 0.85rem 2.5rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .events-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 24px rgba(0,0,0,0.3);
  }

  @media (max-width: 768px) {
    .info-grid {
      grid-template-columns: 1fr;
      padding: 0 2rem 4rem;
    }
    .info-col {
      padding: 2rem 1rem;
    }
  }
</style>
