---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Connect | Silicon Valley College Church" description="Get connected at Silicon Valley College Church. Find a small group, meet people from your campus, and plug into community.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32 page-enter">
    <section class="py-16 text-center">
      <h1 class="font-sans font-black uppercase leading-none" style="font-size: clamp(3rem, 8vw, 8rem);">
        Connect
      </h1>
    </section>
    <section class="mx-auto max-w-2xl px-4 pb-24 flex justify-center">
      <div class="w-full max-w-[640px] relative">
        <!-- Skeleton placeholder while iframe loads -->
        <div id="form-skeleton" class="skeleton-wrap">
          <div class="skel-card">
            <div class="skel-bar" style="width:75%;height:24px;"></div>
            <div class="skel-bar" style="width:55%;height:14px;margin-top:12px;"></div>
            <div class="skel-bar" style="width:50%;height:12px;margin-top:16px;"></div>
          </div>
          <div class="skel-card">
            <div class="skel-bar" style="width:30%;height:14px;"></div>
            <div class="skel-bar" style="width:65%;height:18px;margin-top:16px;"></div>
          </div>
          <div class="skel-card">
            <div class="skel-bar" style="width:30%;height:14px;"></div>
            <div class="skel-bar" style="width:50%;height:32px;margin-top:16px;border-radius:4px;"></div>
          </div>
          <div class="skel-card">
            <div class="skel-bar" style="width:25%;height:14px;"></div>
            <div class="skel-bar" style="width:65%;height:18px;margin-top:16px;"></div>
          </div>
          <div class="skel-card">
            <div class="skel-bar" style="width:22%;height:14px;"></div>
            <div class="skel-bar" style="width:50%;height:32px;margin-top:16px;border-radius:4px;"></div>
          </div>
          <div class="skel-card">
            <div class="skel-bar" style="width:35%;height:14px;"></div>
            <div class="skel-bar" style="width:60%;height:16px;margin-top:16px;"></div>
            <div class="skel-bar" style="width:55%;height:16px;margin-top:10px;"></div>
          </div>
        </div>

        <iframe
          id="connect-form"
          src="https://docs.google.com/forms/d/e/1FAIpQLSc5JIcrm7n63HnFrO2Xv2EqAKDQQOqSnZxF4nhUwFPacNCybw/viewform?embedded=true"
          class="w-full border-0 opacity-0 transition-opacity duration-500"
          height="1547"
          title="SVC Connect"
          loading="lazy"
        >Loading…</iframe>
      </div>
    </section>

    <script>
      const iframe = document.getElementById('connect-form');
      const skeleton = document.getElementById('form-skeleton');
      if (iframe && skeleton) {
        iframe.addEventListener('load', () => {
          iframe.classList.remove('opacity-0');
          skeleton.classList.add('skeleton-hidden');
        });
      }
    </script>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-enter {
    animation: pageEnter 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes pageEnter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .skeleton-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0 16px;
    transition: opacity 0.4s ease;
  }

  .skeleton-wrap.skeleton-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .skel-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 24px;
  }

  .skel-bar {
    background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f0 50%, #e8e8e8 75%);
    background-size: 200% 100%;
    border-radius: 3px;
    height: 14px;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
