---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getImage } from 'astro:assets';

// Community photos for the ghost background collage
import svc01 from '../assets/images/community/svc-01.webp';
import svc02 from '../assets/images/community/svc-02.webp';
import svc03 from '../assets/images/community/svc-03.webp';
import svc04 from '../assets/images/community/svc-04.webp';
import svc05 from '../assets/images/community/svc-05.webp';
import svc06 from '../assets/images/community/svc-06.webp';
import svc07 from '../assets/images/community/svc-07.webp';
import svc08 from '../assets/images/community/svc-08.webp';
import svc09 from '../assets/images/community/svc-09.webp';
import svc10 from '../assets/images/community/svc-10.webp';
import svc11 from '../assets/images/community/svc-11.webp';
import svc12 from '../assets/images/community/svc-12.webp';

// Optimise at build — small size since they're just ghost bg
const bgPhotos = await Promise.all(
  [svc01, svc02, svc03, svc04, svc05, svc06, svc07, svc08, svc09, svc10, svc11, svc12]
    .map(src => getImage({ src, width: 480, format: 'webp', quality: 40 }))
);
---

<BaseLayout
  title="Class of 2030 · Silicon Valley College Church"
  description="Welcome, Class of 2030. Your people are waiting at Silicon Valley College Church — a faith community built for college students in Silicon Valley."
>
  <Nav />

  <main id="c30-main">

    <section id="c30-hero">

      <!-- Noise texture overlay -->
      <div class="c30-noise" aria-hidden="true"></div>

      <!-- Scrolling photo banner — sits between nav and title -->
      <div class="c30-photo-banner" aria-hidden="true">
        <div class="c30-photo-track">
          {bgPhotos.map((img) => (
            <img src={img.src} alt="" loading="lazy" class="c30-banner-img" />
          ))}
          {/* Duplicate for seamless loop */}
          {bgPhotos.map((img) => (
            <img src={img.src} alt="" loading="lazy" class="c30-banner-img" />
          ))}
        </div>
      </div>

      <!-- Red glow behind video -->
      <div class="c30-glow" aria-hidden="true"></div>

      <!-- Floating bokeh orbs — concert light vibes -->
      <div class="c30-bokeh" aria-hidden="true">
        <div class="c30-orb c30-orb-1"></div>
        <div class="c30-orb c30-orb-2"></div>
        <div class="c30-orb c30-orb-3"></div>
        <div class="c30-orb c30-orb-4"></div>
        <div class="c30-orb c30-orb-5"></div>
        <div class="c30-orb c30-orb-6"></div>
        <div class="c30-orb c30-orb-7"></div>
        <div class="c30-orb c30-orb-8"></div>
        <div class="c30-orb c30-orb-9"></div>
        <div class="c30-orb c30-orb-10"></div>
      </div>

      <!-- Canvas for cursor sparkle trail -->
      <canvas id="c30-sparkle-canvas"></canvas>

      <div class="c30-layout">

        <!-- Cinematic title with flowing rectangular text border -->
        <div class="c30-title-row">

          <!--
            The rectangle is traced TWICE in one continuous path (4520 units).
            textLength="2260" fills exactly ONE lap.
            Animating startOffset 0→2260 shifts the text one full lap.
            At every moment the text [S, S+2260] covers the full visible
            rectangle [0,2260] — the second lap of the path provides the
            wrap-around, so there is never a bare gap.
          -->
          <svg class="c30-orbit-svg" viewBox="0 0 1000 182" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <!--
                Two laps of the same rounded rectangle joined as one open path.
                Lap 1 + Lap 2, no Z so it stays a single continuous stroke.
                Each lap perimeter ≈ 2×(980+150) = 2260 units.
              -->
              <!--
                Shifted up 7 units vs original to equalise visual padding:
                top WELCOME gap ≈ bottom WELCOME gap once cap-height offset
                is accounted for. Perimeter unchanged at 2×(980+150)=2260.
              -->
              <path id="c30-rpath"
                d="M 16 9
                   L 984 9   Q 990 9   990 15
                   L 990 153 Q 990 159 984 159
                   L 16 159  Q 10 159  10 153
                   L 10 15   Q 10 9    16 9
                   L 984 9   Q 990 9   990 15
                   L 990 153 Q 990 159 984 159
                   L 16 159  Q 10 159  10 153
                   L 10 15   Q 10 9    16 9"
              />
            </defs>
            <text
              font-family="'Plus Jakarta Sans', sans-serif"
              font-size="14"
              font-weight="700"
              fill="rgba(240,237,232,0.75)"
              letter-spacing="3"
            >
              <textPath href="#c30-rpath" textLength="2260" lengthAdjust="spacing" startOffset="0">
                <animate attributeName="startOffset" from="0" to="2260" dur="32s" repeatCount="indefinite"/>
                WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022; WELCOME &#x2022;
              </textPath>
            </text>
          </svg>

          <h1 class="c30-class-of">Class of 2030</h1>
        </div>

        <!-- Video -->
        <div class="c30-video-wrap">
          <!-- Replace src with your actual video file or use a YouTube embed -->
          <video
            class="c30-video"
            autoplay
            muted
            loop
            playsinline
            poster=""
          >
            <!-- <source src="/videos/church-highlight.mp4" type="video/mp4" /> -->
          </video>
          <!-- Placeholder shown when no video source -->
          <div class="c30-video-placeholder" aria-hidden="true">
            <div class="c30-play-icon">
              <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="30" cy="30" r="29" stroke="rgba(240,237,232,0.2)" stroke-width="1"/>
                <path d="M25 20L42 30L25 40V20Z" fill="rgba(240,237,232,0.5)"/>
              </svg>
            </div>
            <p class="c30-placeholder-label">Your video here</p>
          </div>
        </div>

        <!-- CTA buttons -->
        <div class="c30-ctas">
          <a href="/connect" class="c30-btn c30-btn-primary">
            Get Connected
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M8.5 3.5L13 8l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/about" class="c30-btn c30-btn-ghost">
            More Info
          </a>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── IMPORTS ── */
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  /* ── PAGE BASE ── */
  #c30-main {
    overflow-x: hidden;
    background: #080808;
  }

  /* ── HERO SECTION ── */
  #c30-hero {
    position: relative;
    min-height: 100svh;
    background: #080808;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(80px, 12vh, 120px) 4vw clamp(60px, 8vh, 80px);
    overflow: hidden;
  }

  /* Noise texture */
  .c30-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  /* ── SCROLLING PHOTO BANNER — behind hero title ── */
  .c30-photo-banner {
    position: absolute;
    /* Start just below the fixed header (md:h-32 = 128px, mobile h-20 = 80px) */
    top: 128px;
    left: 0;
    right: 0;
    height: clamp(200px, 30vw, 420px);
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.3;
    /* Fade all edges into the dark background */
    mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    -webkit-mask-composite: source-in;
  }

  .c30-photo-track {
    display: flex;
    gap: 14px;
    height: 100%;
    width: max-content;
    animation: c30BannerScroll 50s linear infinite;
  }

  .c30-banner-img {
    height: 100%;
    width: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 8px;
    filter: grayscale(0.4);
    flex-shrink: 0;
  }

  @keyframes c30BannerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .c30-photo-banner {
      top: 80px; /* mobile header h-20 = 80px */
      height: 140px;
      opacity: 0.22;
    }
  }

  /* Red atmospheric glow */
  .c30-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 65%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(217, 28, 42, 0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── BOKEH ORBS ── */
  .c30-bokeh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .c30-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(1px);
    will-change: transform;
  }

  /* ── Individual orbs — staggered sizes, positions, speeds, colors ── */
  .c30-orb-1 {
    width: 110px; height: 110px;
    top: 12%; left: 8%;
    background: radial-gradient(circle, rgba(217,28,42,0.18) 0%, transparent 70%);
    animation: c30Drift1 22s ease-in-out infinite;
  }
  .c30-orb-2 {
    width: 70px; height: 70px;
    top: 68%; left: 78%;
    background: radial-gradient(circle, rgba(240,237,232,0.12) 0%, transparent 70%);
    animation: c30Drift2 28s ease-in-out infinite;
  }
  .c30-orb-3 {
    width: 140px; height: 140px;
    top: 30%; left: 65%;
    background: radial-gradient(circle, rgba(217,28,42,0.14) 0%, transparent 70%);
    animation: c30Drift3 25s ease-in-out infinite;
  }
  .c30-orb-4 {
    width: 50px; height: 50px;
    top: 80%; left: 20%;
    background: radial-gradient(circle, rgba(240,237,232,0.15) 0%, transparent 70%);
    animation: c30Drift4 18s ease-in-out infinite;
  }
  .c30-orb-5 {
    width: 90px; height: 90px;
    top: 15%; left: 42%;
    background: radial-gradient(circle, rgba(217,28,42,0.1) 0%, transparent 70%);
    animation: c30Drift5 30s ease-in-out infinite;
  }
  .c30-orb-6 {
    width: 60px; height: 60px;
    top: 55%; left: 10%;
    background: radial-gradient(circle, rgba(240,237,232,0.1) 0%, transparent 70%);
    animation: c30Drift1 35s ease-in-out infinite reverse;
  }
  .c30-orb-7 {
    width: 120px; height: 120px;
    top: 40%; left: 88%;
    background: radial-gradient(circle, rgba(217,28,42,0.12) 0%, transparent 70%);
    animation: c30Drift3 20s ease-in-out infinite reverse;
  }
  .c30-orb-8 {
    width: 45px; height: 45px;
    top: 75%; left: 55%;
    background: radial-gradient(circle, rgba(240,237,232,0.13) 0%, transparent 70%);
    animation: c30Drift2 24s ease-in-out infinite reverse;
  }
  .c30-orb-9 {
    width: 80px; height: 80px;
    top: 8%; left: 90%;
    background: radial-gradient(circle, rgba(217,28,42,0.16) 0%, transparent 70%);
    animation: c30Drift4 32s ease-in-out infinite;
  }
  .c30-orb-10 {
    width: 100px; height: 100px;
    top: 60%; left: 35%;
    background: radial-gradient(circle, rgba(240,237,232,0.08) 0%, transparent 70%);
    animation: c30Drift5 27s ease-in-out infinite reverse;
  }

  /* Drift paths — each unique to avoid pattern repetition */
  @keyframes c30Drift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(60px, -40px) scale(1.1); }
    50%      { transform: translate(-30px, 50px) scale(0.9); }
    75%      { transform: translate(40px, 20px) scale(1.05); }
  }
  @keyframes c30Drift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-50px, 30px) scale(1.15); }
    66%      { transform: translate(40px, -60px) scale(0.85); }
  }
  @keyframes c30Drift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    20%      { transform: translate(30px, 50px) scale(0.95); }
    50%      { transform: translate(-60px, -20px) scale(1.12); }
    80%      { transform: translate(20px, -40px) scale(1); }
  }
  @keyframes c30Drift4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%      { transform: translate(-40px, -50px) scale(1.2); }
    70%      { transform: translate(50px, 30px) scale(0.9); }
  }
  @keyframes c30Drift5 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    30%      { transform: translate(45px, 35px) scale(1.08); }
    60%      { transform: translate(-35px, -45px) scale(0.92); }
    85%      { transform: translate(20px, -20px) scale(1.1); }
  }

  /* ── SPARKLE CANVAS ── */
  #c30-sparkle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  /* ── LAYOUT ── */
  .c30-layout {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* ── EYEBROW ── */
  .c30-eyebrow {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(0.55rem, 0.9vw, 0.7rem);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.3);
    margin: 0 0 clamp(1rem, 2.5vw, 1.75rem);
    opacity: 0;
    animation: c30FadeDown 0.6s ease 0.2s forwards;
  }

  /* ── TITLE ROW ── */
  .c30-title-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(80vw, 1280px);
    /* aspect-ratio matches SVG viewBox 1000/182 ≈ 5.49 */
    aspect-ratio: 1000 / 182;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    opacity: 0;
    animation: c30FadeDown 0.7s ease 0.3s forwards;
  }

  /* SVG text border — fills container exactly */
  .c30-orbit-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  .c30-class-of {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(5rem, 11vw, 14rem);
    font-weight: 400;
    color: #F0EDE8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 0.88;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  /* ── VIDEO WRAPPER ── */
  .c30-video-wrap {
    position: relative;
    width: min(80vw, 1280px);
    aspect-ratio: 16 / 9;
    border-radius: clamp(16px, 2vw, 24px);
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      0 0 0 1px rgba(217, 28, 42, 0.15),
      0 40px 100px rgba(0, 0, 0, 0.8),
      0 0 80px rgba(217, 28, 42, 0.1);
    opacity: 0;
    animation: c30VideoReveal 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.5s forwards;
  }

  .c30-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder (shown when no video source) */
  .c30-video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #141414 0%, #0e0e0e 50%, #161010 100%);
    gap: 1rem;
  }

  /* Hide placeholder if video loads */
  .c30-video:not([src=""]) + .c30-video-placeholder,
  .c30-video:has(source) + .c30-video-placeholder {
    display: none;
  }

  .c30-play-icon svg {
    width: clamp(40px, 6vw, 64px);
    height: clamp(40px, 6vw, 64px);
  }

  .c30-placeholder-label {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(0.6rem, 1vw, 0.75rem);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.2);
    margin: 0;
  }

  /* ── CTA BUTTONS ── */
  .c30-ctas {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    opacity: 0;
    animation: c30FadeUp 0.6s ease 1.1s forwards;
  }

  .c30-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(0.72rem, 1.1vw, 0.85rem);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: clamp(0.75rem, 1.5vw, 0.95rem) clamp(1.5rem, 3vw, 2.25rem);
    border-radius: 100px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .c30-btn-primary {
    background: #D91C2A;
    color: #F0EDE8;
    box-shadow: 0 4px 24px rgba(217, 28, 42, 0.4);
  }

  .c30-btn-primary:hover {
    background: #e82233;
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(217, 28, 42, 0.55);
  }

  .c30-btn-ghost {
    background: transparent;
    color: rgba(240, 237, 232, 0.65);
    border: 1.5px solid rgba(240, 237, 232, 0.2);
  }

  .c30-btn-ghost:hover {
    color: #F0EDE8;
    border-color: rgba(240, 237, 232, 0.45);
    transform: translateY(-2px);
  }

  /* ── KEYFRAMES ── */
  @keyframes c30FadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes c30FadeDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

@keyframes c30VideoReveal {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── RESPONSIVE ── */

  /* Tablet */
  @media (max-width: 768px) {
    #c30-hero {
      padding: clamp(70px, 10vh, 100px) 4vw clamp(40px, 6vh, 60px);
    }

    .c30-title-row,
    .c30-video-wrap {
      width: 92vw;
    }

    .c30-class-of {
      font-size: clamp(3.5rem, 9vw, 6rem);
      letter-spacing: 0.05em;
    }

    .c30-title-row {
      margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    }

    /* Scale down bokeh */
    .c30-orb { transform: scale(0.7); }
  }

  /* Mobile */
  @media (max-width: 480px) {
    #c30-hero {
      padding: 80px 4vw 40px;
    }

    .c30-class-of {
      font-size: clamp(2.6rem, 13vw, 4rem);
      letter-spacing: 0.02em;
    }

    .c30-title-row {
      margin-bottom: 1.5rem;
    }

    .c30-video-wrap {
      width: 92vw;
      border-radius: 12px;
    }

    .c30-ctas {
      flex-direction: column;
      width: 92vw;
      margin-top: 1.25rem;
    }

    .c30-btn {
      width: 100%;
      justify-content: center;
    }

    /* Scale down WELCOME orbit text for mobile */
    .c30-orbit-svg text {
      font-size: 8;
      letter-spacing: 1.5;
    }

    /* Smaller bokeh */
    .c30-orb { transform: scale(0.5); }
  }
</style>

<!-- Nav inversion for dark page -->
<style is:global>
  /* Background */
  body:has(#c30-main) header.fixed {
    background: rgba(8, 8, 8, 0.85) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Desktop nav links */
  body:has(#c30-main) header.fixed nav a {
    color: rgba(240, 237, 232, 0.75) !important;
  }
  body:has(#c30-main) header.fixed nav a:hover {
    color: #D91C2A !important;
  }

  /* Hamburger bars */
  body:has(#c30-main) header.fixed .hamburger-bar {
    background: #F0EDE8 !important;
  }

  /* Mobile dropdown */
  body:has(#c30-main) #mobile-menu nav {
    background: #0d0d0d !important;
    border-color: rgba(255, 255, 255, 0.08) !important;
  }
  body:has(#c30-main) #mobile-menu a {
    color: rgba(240, 237, 232, 0.8) !important;
    border-color: rgba(255, 255, 255, 0.08) !important;
  }

  /* Footer inversion */
  body:has(#c30-main) footer {
    background: #080808 !important;
    border-color: rgba(255, 255, 255, 0.06) !important;
  }
  body:has(#c30-main) footer p {
    color: rgba(240, 237, 232, 0.7) !important;
  }
  body:has(#c30-main) footer a {
    color: rgba(240, 237, 232, 0.7) !important;
  }
  body:has(#c30-main) footer a:hover {
    color: #F0EDE8 !important;
  }

  /* Logo — invert black logo to white */
  body:has(#c30-main) .logo-main,
  body:has(#c30-main) .logo-depth {
    filter: brightness(0) invert(1) !important;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const canvas = document.getElementById('c30-sparkle-canvas') as HTMLCanvasElement | null;
    const hero = document.getElementById('c30-hero');
    if (!canvas || !hero) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Palette: reds + warm whites
    const colors = [
      'rgba(217,28,42,',   // red
      'rgba(230,60,70,',   // lighter red
      'rgba(240,237,232,', // warm white
      'rgba(255,200,180,', // peachy glow
    ];

    interface Particle {
      x: number; y: number;
      vx: number; vy: number;
      life: number; maxLife: number;
      size: number;
      color: string;
    }

    let particles: Particle[] = [];
    let raf = 0;
    let lastX = 0;
    let lastY = 0;

    function resize() {
      const rect = hero!.getBoundingClientRect();
      canvas!.width = rect.width * devicePixelRatio;
      canvas!.height = rect.height * devicePixelRatio;
      ctx!.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }

    function spawn(x: number, y: number, count: number) {
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 0.4 + Math.random() * 1.8;
        particles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 0.5, // slight upward bias
          life: 1,
          maxLife: 0.4 + Math.random() * 0.4,
          size: 1.5 + Math.random() * 3,
          color: colors[Math.floor(Math.random() * colors.length)],
        });
      }
    }

    function tick() {
      const w = canvas!.width / devicePixelRatio;
      const h = canvas!.height / devicePixelRatio;
      ctx!.clearRect(0, 0, w, h);

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.life -= 1 / 60 / p.maxLife;
        if (p.life <= 0) { particles.splice(i, 1); continue; }

        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.02; // gravity
        p.vx *= 0.98; // drag

        const alpha = p.life * 0.85;
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
        ctx!.fillStyle = p.color + alpha + ')';
        ctx!.fill();
      }

      raf = requestAnimationFrame(tick);
    }

    // Mouse tracking
    function onMove(e: MouseEvent) {
      const rect = hero!.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      // Only spawn if cursor has moved enough (avoids static clusters)
      const dx = x - lastX;
      const dy = y - lastY;
      if (dx * dx + dy * dy > 16) {
        spawn(x, y, 2);
        lastX = x;
        lastY = y;
      }
    }

    // Touch tracking for mobile
    function onTouch(e: TouchEvent) {
      const rect = hero!.getBoundingClientRect();
      for (const touch of Array.from(e.touches)) {
        spawn(touch.clientX - rect.left, touch.clientY - rect.top, 3);
      }
    }

    resize();
    tick();

    // ResizeObserver catches layout shifts from View Transitions,
    // font loading, and dynamic content — fixes the "offset on first
    // visit" bug where canvas dimensions are stale.
    const ro = new ResizeObserver(resize);
    ro.observe(hero);

    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('touchmove', onTouch, { passive: true });

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      ro.disconnect();
      hero.removeEventListener('mousemove', onMove);
      hero.removeEventListener('touchmove', onTouch);
    }, { once: true });
  });
</script>

