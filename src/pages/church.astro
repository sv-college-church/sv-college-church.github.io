---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Church | Silicon Valley College Church" description="Join us Sundays at 12 PM in Santa Clara. A college church gathering young adults and students from across Silicon Valley.">
  <Nav />
  <main class="min-h-screen bg-paper pt-20 md:pt-32">

    <!-- Regular service banner (shown while Easter is default) -->
    <div class="announcement-banner">
      <span class="banner-text">
        <span class="label-full">☀️ REGULAR SERVICE · SUNDAYS · 12 PM · SANTA CLARA</span>
        <span class="label-short">☀️ SUNDAYS · 12 PM</span>
      </span>
      <button class="easter-btn" aria-label="Switch to regular Sunday service details">
        <span class="btn-default"><span class="label-full">SEE REGULAR SERVICE</span><span class="label-short">REGULAR →</span></span>
        <span class="btn-reset"><span class="label-full">← BACK TO EASTER</span><span class="label-short">← EASTER</span></span>
      </button>
    </div>

    <!-- Hero -->
    <section class="py-12 text-center md:py-16">
      <h1 class="font-sans font-black uppercase leading-none" style="font-size: clamp(3rem, 8vw, 8rem);">
        Sundays at SVC
      </h1>
    </section>

    <!-- WHEN + WHERE side by side -->
    <section class="when-where border-t border-ink/10">
      <!-- When -->
      <div class="info-col" data-animate>
        <p class="section-label">When</p>
        <div class="info-content">
          <p class="display-primary" id="when-primary">April 5</p>
          <p class="display-bold" id="when-bold">12 PM</p>
          <button class="easter-inline-btn" id="easter-inline"><span class="inline-default">Regular Sundays? →</span><span class="inline-reset">← Back to Easter</span></button>
        </div>
      </div>

      <!-- Divider -->
      <div class="col-divider" aria-hidden="true"></div>

      <!-- Where -->
      <div class="info-col" data-animate>
        <p class="section-label">Where</p>
        <div class="info-content">
          <p class="display-primary" id="where-primary">The Kings Academy</p>
          <p class="display-secondary" id="where-secondary">562 N Britton Ave</p>
          <a
            href="https://maps.app.goo.gl/Qxu9AUFbXdcRdcSY7"
            target="_blank"
            rel="noopener noreferrer"
            class="directions-link"
            id="directions-link"
          >
            Get Directions →
          </a>
        </div>
      </div>
    </section>

    <!-- Reset pill (appears when toggled away from Easter default) -->
    <div class="easter-reset" id="easter-reset" aria-live="polite">
      <button id="reset-btn">← Back to Easter service</button>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint border-t border-ink/10" aria-hidden="true">
      <a href="#what" class="scroll-arrow" tabindex="-1">↓</a>
    </div>

    <!-- WHAT -->
    <section id="what" class="reveal-section border-t border-ink/10">
      <div class="reveal-inner what-inner" data-animate>
        <div class="section-rule"></div>
        <p class="section-label">What to Expect</p>
        <p class="body-text">
          Every Sunday, students from SJSU, Stanford, UC Santa Cruz, De Anza, and beyond pack into our church building to worship together. Expect live praise, a message worth hearing, and lunch after. It usually ends with a pickup basketball game nobody planned. Come as you are — we'd love to have you.
        </p>
        <a
          href="https://maps.app.goo.gl/XnKMeboUpYpEXNxB8"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          Get Directions
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Announcement banner ── */
  .announcement-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    background: #0A0A0A;
    padding: 1.1rem 2rem;
  }

  .banner-text {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F5F5F0;
    line-height: 1;
  }

  .easter-btn {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    line-height: 1;
    color: #F5F5F0;
    background: #D91C2A;
    border: 1px solid transparent;
    padding: 0.65rem 1.6rem;
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .easter-btn:hover { background: #b51623; }

  .easter-btn.is-reset {
    background: transparent;
    border-color: rgb(245 245 240 / 0.5);
  }

  .easter-btn.is-reset:hover { background: rgb(245 245 240 / 0.1); }

  .btn-default, .btn-reset {
    display: block;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  .btn-reset {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }

  .easter-btn.is-reset .btn-default { opacity: 0; }
  .easter-btn.is-reset .btn-reset { opacity: 1; }

  /* ── Easter inline trigger (below 12 PM) ── */
  .easter-inline-btn {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #D91C2A;
    background: none;
    border: none;
    cursor: pointer;
    margin-top: 1.5rem;
    padding: 0;
    position: relative;
    transition: opacity 0.2s ease;
  }

  .easter-inline-btn:hover { opacity: 0.7; }

  .inline-default, .inline-reset {
    transition: opacity 0.15s ease;
  }

  .inline-reset {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }

  .easter-inline-btn.is-reset .inline-default { opacity: 0; }
  .easter-inline-btn.is-reset .inline-reset { opacity: 1; }

  /* ── Easter reset pill ── */
  .easter-reset {
    display: flex;
    justify-content: center;
    padding: 0.75rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .easter-reset.visible {
    opacity: 1;
    pointer-events: all;
  }

  #reset-btn {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.62);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  #reset-btn:hover {
    color: rgb(10 10 10 / 0.8);
  }

  /* ── WHEN + WHERE side by side ── */
  .when-where {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    grid-template-rows: 1fr auto auto 1fr;
    min-height: 50vh;
  }

  .info-col {
    display: grid;
    grid-row: span 4;
    grid-template-rows: subgrid;
    justify-items: center;
    text-align: center;
    padding: 0 3rem;
  }

  .info-col .section-label {
    grid-row: 2;
    align-self: end;
    padding-bottom: 1rem;
  }

  .col-divider {
    grid-row: span 4;
    background: rgb(10 10 10 / 0.1);
  }

  .info-content {
    grid-row: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Reveal (data-animate) ── */
  [data-animate] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Section label ── */
  .section-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(10 10 10 / 0.60);
    margin-bottom: 1.75rem;
  }

  /* When / Where labels */
  .info-col .section-label {
    font-size: clamp(2rem, 4vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.50);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .what-inner .section-label {
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.65);
    margin-bottom: 2rem;
  }

  /* ── Display text ── */
  .display-primary {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5.5vw, 6rem);
    font-weight: 400;
    font-style: italic;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: rgb(10 10 10);
  }

  #where-primary {
    font-size: clamp(1.6rem, 3vw, 3.4rem);
    white-space: nowrap;
  }

  .display-bold {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 8vw, 9rem);
    font-weight: 700;
    font-style: normal;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: rgb(10 10 10);
    margin-top: 0.1em;
  }

  .display-secondary {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 3vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.01em;
    color: rgb(10 10 10 / 0.65);
    margin-top: 0.35em;
  }

  /* ── Directions link ── */
  .directions-link {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.62);
    text-decoration: none;
    margin-top: 2rem;
    transition: color 0.2s ease;
  }

  .directions-link:hover {
    color: rgb(10 10 10);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .scroll-arrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #D91C2A;
    text-decoration: none;
    animation: nudge 2.4s ease-in-out infinite;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  .scroll-arrow:hover {
    opacity: 0.7;
  }

  @keyframes nudge {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(5px); opacity: 1; }
  }

  /* ── WHAT section ── */
  .reveal-section {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
  }

  .reveal-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .section-rule {
    width: 1px;
    height: 3.5rem;
    background: rgb(10 10 10 / 0.18);
    margin-bottom: 1.75rem;
  }

  .what-inner {
    max-width: 60rem;
  }

  .body-text {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.75;
    color: rgb(10 10 10 / 0.82);
    margin-bottom: 3rem;
  }

  .cta-button {
    display: inline-block;
    border: 1px solid rgb(10 10 10);
    padding: 0.8rem 2.75rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgb(10 10 10);
    text-decoration: none;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .cta-button:hover {
    background: rgb(10 10 10);
    color: #F5F5F0;
  }

  /* ── Short/full label switching ── */
  .label-short { display: none; }

  /* ── Mobile: stack when/where + compact banner ── */
  @media (max-width: 640px) {
    .when-where {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1px auto;
      min-height: unset;
    }

    .info-col {
      grid-row: auto;
      grid-template-rows: auto auto;
      padding: 4rem 3rem;
    }

    .info-col .section-label {
      grid-row: auto;
    }

    .info-content {
      grid-row: auto;
    }

    .col-divider {
      grid-row: auto;
      width: 100%;
      height: 1px;
      background: rgb(10 10 10 / 0.1);
    }

    /* Banner: slim single row with condensed text */
    .announcement-banner {
      gap: 0.6rem;
      padding: 0.7rem 1rem;
    }

    .banner-text .label-full { display: none; }
    .banner-text .label-short { display: inline; }

    .easter-btn .label-full { display: none; }
    .easter-btn .label-short { display: inline; }

    .banner-text {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
    }

    .easter-btn {
      font-size: 0.68rem;
      padding: 0.45rem 0.85rem;
      letter-spacing: 0.14em;
      flex-shrink: 0;
    }
  }
</style>

<script>
  var CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

  var REGULAR = {
    whenPrimary: 'Sundays',
    wherePrimary: '2346 Walsh Ave',
    whereSecondary: 'Santa Clara, CA',
    mapsUrl: 'https://maps.app.goo.gl/XnKMeboUpYpEXNxB8',
  };

  var EASTER = {
    whenPrimary: 'April 5',
    wherePrimary: 'The Kings Academy',
    whereSecondary: '562 N Britton Ave',
    mapsUrl: 'https://maps.app.goo.gl/Qxu9AUFbXdcRdcSY7',
  };

  function scramble(el, target) {
    var INTERVAL = 28;
    var STEPS = 18;
    var step = 0;
    var scrambleLen = el.textContent.length;

    var run = setInterval(function () {
      step++;
      var progress = step / STEPS;
      var result = '';

      for (var i = 0; i < scrambleLen; i++) {
        var resolveThreshold = (i / scrambleLen) * 0.65 + 0.35;
        if (progress >= resolveThreshold) {
          result += (target[i] !== undefined ? target[i] : '');
        } else {
          result += CHARS[Math.floor(Math.random() * CHARS.length)];
        }
      }

      el.textContent = result;

      if (step >= STEPS) {
        clearInterval(run);
        el.textContent = target;
      }
    }, INTERVAL);
  }

  document.addEventListener('astro:page-load', () => {
    // Only run on the church page
    var easterBtn = document.querySelector('.easter-btn');
    var inlineBtn = document.getElementById('easter-inline');
    if (!easterBtn || !inlineBtn) return;

    var isEaster = true;

    function applyState(data) {
      scramble(document.getElementById('when-primary'), data.whenPrimary);
      scramble(document.getElementById('where-primary'), data.wherePrimary);
      scramble(document.getElementById('where-secondary'), data.whereSecondary);

      var link = document.getElementById('directions-link');
      setTimeout(function () { link.href = data.mapsUrl; }, 300);
    }

    function toggleEaster() {
      isEaster = !isEaster;
      applyState(isEaster ? EASTER : REGULAR);

      document.querySelectorAll('.easter-btn').forEach(function (btn) {
        btn.classList.toggle('is-reset', !isEaster);
      });
      if (inlineBtn) inlineBtn.classList.toggle('is-reset', !isEaster);

      var reset = document.getElementById('easter-reset');
      if (reset) reset.classList.toggle('visible', !isEaster);
    }

    easterBtn.addEventListener('click', function () {
      toggleEaster();
    });

    inlineBtn.addEventListener('click', function () {
      toggleEaster();
    });

    var resetBtn = document.getElementById('reset-btn');
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        if (!isEaster) toggleEaster();
      });
    }
  });
</script>
