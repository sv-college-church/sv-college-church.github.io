---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Gathering | Silicon Valley College Church" description="Join us Sundays at 12 PM in Santa Clara. A college church gathering young adults and students from across Silicon Valley.">
  <div class="page-shell">
  <Nav />
  <main class="bg-paper pt-20 md:pt-32 flex-1">

    <!-- Hero -->
    <section class="py-12 text-center md:py-16">
      <h1 class="font-sans font-black uppercase leading-none" style="font-size: clamp(3rem, 8vw, 8rem);">
        Sundays at SVC
      </h1>
    </section>

    <!-- WHEN + WHERE side by side -->
    <section class="when-where border-t border-ink/10">
      <!-- When -->
      <div class="info-col" data-animate>
        <p class="section-label">When</p>
        <div class="info-content">
          <p class="display-primary" id="when-primary">Sundays</p>
          <p class="display-bold" id="when-bold">12 PM</p>
        </div>
      </div>

      <!-- Divider -->
      <div class="col-divider" aria-hidden="true"></div>

      <!-- Where -->
      <div class="info-col" data-animate>
        <p class="section-label">Where</p>
        <div class="info-content">
          <p class="display-primary" id="where-primary">2346 Walsh Ave</p>
          <p class="display-secondary" id="where-secondary">Santa Clara, CA</p>
          <a
            href="https://maps.app.goo.gl/XnKMeboUpYpEXNxB8"
            target="_blank"
            rel="noopener noreferrer"
            class="directions-link"
            id="directions-link"
          >
            Get Directions →
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
  </div>
</BaseLayout>

<style>
  .page-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── WHEN + WHERE side by side ── */
  .when-where {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    grid-template-rows: 1fr auto auto 1fr;
    min-height: 40vh;
  }

  .info-col {
    display: grid;
    grid-row: span 4;
    grid-template-rows: subgrid;
    justify-items: center;
    text-align: center;
    padding: 0 3rem;
  }

  .info-col .section-label {
    grid-row: 2;
    align-self: end;
    padding-bottom: 1rem;
  }

  .col-divider {
    grid-row: span 4;
    background: rgb(10 10 10 / 0.1);
  }

  .info-content {
    grid-row: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Reveal (data-animate) ── */
  [data-animate] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Section label ── */
  .section-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(10 10 10 / 0.60);
    margin-bottom: 1.75rem;
  }

  /* When / Where labels */
  .info-col .section-label {
    font-size: clamp(2rem, 4vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.50);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .what-inner .section-label {
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.65);
    margin-bottom: 2rem;
  }

  /* ── Display text ── */
  .display-primary {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5.5vw, 6rem);
    font-weight: 400;
    font-style: italic;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: rgb(10 10 10);
  }

  #where-primary {
    font-size: clamp(1.6rem, 3vw, 3.4rem);
    white-space: nowrap;
  }

  .display-bold {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 8vw, 9rem);
    font-weight: 700;
    font-style: normal;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: rgb(10 10 10);
    margin-top: 0.1em;
  }

  .display-secondary {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 3vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.01em;
    color: rgb(10 10 10 / 0.65);
    margin-top: 0.35em;
  }

  /* ── Directions link ── */
  .directions-link {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgb(10 10 10 / 0.62);
    text-decoration: none;
    margin-top: 2rem;
    transition: color 0.2s ease;
  }

  .directions-link:hover {
    color: rgb(10 10 10);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .scroll-arrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #D91C2A;
    text-decoration: none;
    animation: nudge 2.4s ease-in-out infinite;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  .scroll-arrow:hover {
    opacity: 0.7;
  }

  @keyframes nudge {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(5px); opacity: 1; }
  }

  /* ── WHAT section ── */
  .reveal-section {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
  }

  .reveal-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .section-rule {
    width: 1px;
    height: 3.5rem;
    background: rgb(10 10 10 / 0.18);
    margin-bottom: 1.75rem;
  }

  .what-inner {
    max-width: 60rem;
  }

  .body-text {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.75;
    color: rgb(10 10 10 / 0.82);
    margin-bottom: 3rem;
  }

  .cta-button {
    display: inline-block;
    border: 1px solid rgb(10 10 10);
    padding: 0.8rem 2.75rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgb(10 10 10);
    text-decoration: none;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .cta-button:hover {
    background: rgb(10 10 10);
    color: #F5F5F0;
  }

  /* ── Short/full label switching ── */
  .label-short { display: none; }

  /* ── Mobile: stack when/where + compact banner ── */
  @media (max-width: 640px) {
    .when-where {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1px auto;
      min-height: unset;
    }

    .info-col {
      grid-row: auto;
      grid-template-rows: auto auto;
      padding: 4rem 3rem;
    }

    .info-col .section-label {
      grid-row: auto;
    }

    .info-content {
      grid-row: auto;
    }

    .col-divider {
      grid-row: auto;
      width: 100%;
      height: 1px;
      background: rgb(10 10 10 / 0.1);
    }

  }
</style>

